#!/bin/bash

# Lightweight telemetry for hook events via PostHog — fire-and-forget, never blocks
_aif_hook_telemetry() {
  local _cfg="${HOME}/.aiframework/config"
  [[ -f "$_cfg" ]] && grep -q 'telemetry: false' "$_cfg" 2>/dev/null && return 0
  local _event="$1"; shift
  local _ver; _ver=$(cat "$(git rev-parse --show-toplevel 2>/dev/null)/VERSION" 2>/dev/null || echo "0.0.0")
  local _mid; _mid=$(echo "${HOSTNAME:-x}:${USER:-x}" | shasum -a 256 2>/dev/null | cut -d' ' -f1 || echo "x")
  local _os="unknown"; case "$(uname -s 2>/dev/null)" in Darwin*) _os="macos";; Linux*) _os="linux";; MINGW*|MSYS*) _os="windows";; esac
  local _extra=""; for _kv in "$@"; do _extra="${_extra:+$_extra, }\"${_kv%%=*}\": \"${_kv#*=}\""; done
  command -v curl &>/dev/null && curl -fsSL --connect-timeout 2 --max-time 3 \
    -X POST -H "Content-Type: application/json" \
    -d "{\"api_key\":\"phc_BYZQuJ4BgzbyYmRqzDxQfzHPeG7dQucyYwg9MU4D8Hx4\",\"event\":\"$_event\",\"distinct_id\":\"$_mid\",\"properties\":{\"version\":\"$_ver\",\"platform\":\"$_os\"${_extra:+, $_extra}}}" \
    "https://eu.i.posthog.com/capture/" &>/dev/null || true
}

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  aiframework Pre-Push Quality Gate"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Check if aiframework files are stale
ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
if [[ -f ".aiframework/.file_hashes" ]]; then
  # shellcheck source=../lib/freshness/track.sh
  source "$ROOT_DIR/lib/freshness/track.sh" 2>/dev/null || true
  drift=$(freshness_check_drift "." 2>/dev/null || echo "unknown")
  if [[ "$drift" == drifted:* ]]; then
    echo -e "\033[1;33m[WARN]\033[0m  aiframework: key files changed since last scan"
    echo "         Run: aiframework refresh"
  fi
fi

CHANGED_FILES=$(git diff --name-only HEAD~1 HEAD 2>/dev/null)

SKIP_PATTERNS="^docs/|^scripts/|^tools/|^\.github/|^\.githooks/|^CLAUDE\.md$|^CONTRIBUTING\.md$|^SETUP-DEV\.md$|^STATUS\.md$|^CHANGELOG\.md$|^VERSION$|^AUTOMATION-PLAYBOOK.*$|^LICENSE$|^README\.md$|^\.env|^\.gitignore$|^docs/"

NEEDS_CHECK=false
for file in $CHANGED_FILES; do
  if ! echo "$file" | grep -qE "$SKIP_PATTERNS"; then
    NEEDS_CHECK=true
    break
  fi
done

if [ "$NEEDS_CHECK" = false ]; then
  echo "  Only non-app files changed — skipping quality checks"
  exit 0
fi
# Gate 1: Lint
if ! command -v shellcheck >/dev/null 2>&1; then
  echo "  [1/1] shellcheck not installed — skipping lint"
else
echo "  [1/1] Linting..."
find . -name '*.sh' -not -path '*/.git/*' -not -path '*/vault/*' | xargs shellcheck --severity=error 2>&1
if [ $? -ne 0 ]; then
  echo "  BLOCKED: Lint errors. Fix before pushing."
  _aif_hook_telemetry "prepush_blocked" "reason=lint" &>/dev/null &
  exit 1
fi
echo "  [1/1] Lint passed"
fi

# Invariant checks — domain-specific
CHANGED=$(git diff --name-only HEAD~1 HEAD 2>/dev/null)
INVARIANT_FAIL=false
# Exclude files that legitimately contain patterns (validators, generators, hooks templates, tests)
INVARIANT_EXCLUDE='lib/validators/|lib/generators/|\.githooks/|tests/'
# INV-2: Database invariant: no raw SQL strings in changed files
while IFS= read -r f; do
  [ -z "$f" ] && continue
  if [ -f "$f" ] && grep -nE '(SELECT\s+.+\s+FROM|INSERT\s+INTO|UPDATE\s+.+\s+SET|DELETE\s+FROM|DROP\s+TABLE)' "$f" | grep -vE '(migration|seed|\.sql$)' > /dev/null 2>&1; then
    echo "  WARNING: $f may contain raw SQL — use ORM or query builder"
    INVARIANT_FAIL=true
  fi
done < <(echo "$CHANGED" | grep -vE '\.(md|txt|yml|yaml|json)$' | grep -vE "$INVARIANT_EXCLUDE")
# INV: AI/LLM trust boundary: check for unsanitized LLM output usage
while IFS= read -r f; do
  [ -z "$f" ] && continue
  if [ -f "$f" ] && grep -nE '(innerHTML|dangerouslySetInnerHTML|eval\(|exec\()' "$f" > /dev/null 2>&1; then
    echo "  WARNING: $f may use unsanitized output — check LLM trust boundary"
    INVARIANT_FAIL=true
  fi
done < <(echo "$CHANGED" | grep -vE '\.(md|txt|yml|yaml|json)$' | grep -vE "$INVARIANT_EXCLUDE")
# INV: No secrets in source code
while IFS= read -r f; do
  [ -z "$f" ] && continue
  if [ -f "$f" ] && grep -nE '(ghp_[a-zA-Z0-9]{36}|sk-ant-|sk-proj-|AKIA[A-Z0-9]{16}|password\s*=\s*["\x27][^"\x27]+["\x27])' "$f" > /dev/null 2>&1; then
    echo "  WARNING: $f may contain hardcoded secrets"
    INVARIANT_FAIL=true
  fi
done < <(echo "$CHANGED" | grep -vE '\.(md|txt|yml|yaml|json|lock)$' | grep -vE "$INVARIANT_EXCLUDE")
if [ "$INVARIANT_FAIL" = true ]; then
  echo ""
  echo "  BLOCKED: Invariant violations detected."
  echo "  Fix the issues above before pushing."
  echo "  To bypass (not recommended): git push --no-verify"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  _aif_hook_telemetry "prepush_blocked" "reason=invariant" &>/dev/null &
  exit 1
fi
# Version check
if command -v aiframework-update-check >/dev/null 2>&1; then
  _upd=$(aiframework-update-check 2>/dev/null || true)
  if [[ "$_upd" == UPGRADE_AVAILABLE* ]]; then
    echo "  [aiframework] New version available: ${_upd#UPGRADE_AVAILABLE }"
    echo "  Run: aiframework update"
  fi
fi

# Auto-refresh: regenerate aiframework output if key files drifted
if command -v aiframework >/dev/null 2>&1; then
  _drift=$(freshness_check_drift "." 2>/dev/null || echo "unknown")
  if [[ "$_drift" == drifted:* ]]; then
    echo "  [refresh] Key files changed — running aiframework refresh..."
    aiframework refresh --target . --non-interactive 2>&1 | tail -3
    # Auto-commit refreshed files if any changed
    if [[ -n "$(git diff --name-only 2>/dev/null)" ]]; then
      git add CLAUDE.md .claude/ vault/ .aiframework/ 2>/dev/null || true
      git commit -m "chore(aiframework): auto-refresh on push [skip ci]" --no-verify 2>/dev/null || true
      echo "  [refresh] Auto-committed refreshed files"
    fi
  fi
fi

# Suggest /aif-evolve if learnings have accumulated
_evolve_marker=".aiframework/.last_evolve_count"
_last_evolve=0
[[ -f "$_evolve_marker" ]] && _last_evolve=$(cat "$_evolve_marker" 2>/dev/null | tr -d '[:space:]')
_current_learnings=$(cat tools/learnings/*-learnings.jsonl 2>/dev/null | wc -l | tr -d ' ')
_new_learnings=$(( _current_learnings - _last_evolve ))
if [[ $_new_learnings -ge 5 ]]; then
  echo "  [evolve] $_new_learnings new learnings since last /aif-evolve"
  echo "           Run /aif-evolve to promote learnings to CLAUDE.md rules"
  echo ""
fi

echo ""
echo "  All gates passed — push allowed"
echo "  TIP: Run /review and /cso before creating a PR"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
_aif_hook_telemetry "prepush_passed" &>/dev/null &
exit 0
