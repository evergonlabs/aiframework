#!/usr/bin/env bash
# aiframework-update-check — Detect new versions and stale generated files
#
# Output protocol (one line, machine-readable):
#   UPGRADE_AVAILABLE <local_version> <remote_version>
#   DRIFT_DETECTED <drifted_files>
#   UP_TO_DATE
#   (empty = check failed or disabled)
#
# Designed to be called from CLAUDE.md session start or pre-push hooks.
# Fast: cached results, no network call more than once per hour.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"

# Config
CACHE_DIR="${HOME}/.aiframework"
CACHE_FILE="$CACHE_DIR/last-update-check"
SNOOZE_FILE="$CACHE_DIR/update-snoozed"
CONFIG_FILE="$CACHE_DIR/config"
CACHE_TTL_UPTODATE=3600      # 1 hour
CACHE_TTL_UPGRADE=43200       # 12 hours
GITHUB_REPO="evergonlabs/aiframework"

# ── Helpers ──

now_epoch() {
  date +%s
}

local_version() {
  cat "$ROOT_DIR/VERSION" 2>/dev/null || echo "0.0.0"
}

# Compare semver: returns 0 if $1 < $2
version_lt() {
  local IFS=.
  local i a=($1) b=($2)
  for ((i=0; i<3; i++)); do
    local av="${a[$i]:-0}" bv="${b[$i]:-0}"
    if ((av < bv)); then return 0; fi
    if ((av > bv)); then return 1; fi
  done
  return 1  # equal
}

# ── Config ──

is_check_disabled() {
  [[ -f "$CONFIG_FILE" ]] && grep -q 'update_check: false' "$CONFIG_FILE" 2>/dev/null
}

is_auto_upgrade() {
  [[ -f "$CONFIG_FILE" ]] && grep -q 'auto_upgrade: true' "$CONFIG_FILE" 2>/dev/null
}

# ── Snooze ──

is_snoozed() {
  [[ ! -f "$SNOOZE_FILE" ]] && return 1
  local snoozed_version snoozed_level snoozed_epoch
  read -r snoozed_version snoozed_level snoozed_epoch < "$SNOOZE_FILE" 2>/dev/null || return 1

  # Validate fields
  [[ -z "$snoozed_version" || -z "$snoozed_level" || -z "$snoozed_epoch" ]] && return 1

  # If remote version changed, reset snooze
  local remote="$1"
  if [[ -n "$remote" && "$remote" != "$snoozed_version" ]]; then
    rm -f "$SNOOZE_FILE"
    return 1
  fi

  # Escalating backoff: level 1=24h, level 2=48h, level 3+=7d
  local now
  now=$(now_epoch)
  local ttl=86400
  case "$snoozed_level" in
    1) ttl=86400 ;;   # 24 hours
    2) ttl=172800 ;;  # 48 hours
    *) ttl=604800 ;;  # 7 days
  esac

  local elapsed=$((now - snoozed_epoch))
  [[ $elapsed -lt $ttl ]]
}

write_snooze() {
  local version="$1"
  local current_level=0
  if [[ -f "$SNOOZE_FILE" ]]; then
    current_level=$(awk '{print $2}' "$SNOOZE_FILE" 2>/dev/null || echo 0)
  fi
  local new_level=$((current_level + 1))
  mkdir -p "$CACHE_DIR"
  echo "$version $new_level $(now_epoch)" > "$SNOOZE_FILE"
}

# ── Cache ──

check_cache() {
  [[ ! -f "$CACHE_FILE" ]] && return 1
  local cached_status cached_local cached_remote cached_epoch
  read -r cached_status cached_local cached_remote cached_epoch < "$CACHE_FILE" 2>/dev/null || return 1

  local now
  now=$(now_epoch)
  local elapsed=$((now - cached_epoch))

  case "$cached_status" in
    UP_TO_DATE)
      [[ $elapsed -lt $CACHE_TTL_UPTODATE ]] && { echo "UP_TO_DATE"; return 0; }
      ;;
    UPGRADE_AVAILABLE)
      [[ $elapsed -lt $CACHE_TTL_UPGRADE ]] && { echo "UPGRADE_AVAILABLE $cached_local $cached_remote"; return 0; }
      ;;
  esac
  return 1
}

write_cache() {
  mkdir -p "$CACHE_DIR"
  echo "$1 $(now_epoch)" > "$CACHE_FILE"
}

# ── Remote Version Check ──

fetch_remote_version() {
  local url="https://raw.githubusercontent.com/${GITHUB_REPO}/main/VERSION"
  if command -v curl &>/dev/null; then
    curl -fsSL --connect-timeout 3 --max-time 5 "$url" 2>/dev/null | tr -d '[:space:]'
  elif command -v wget &>/dev/null; then
    wget -qO- --timeout=5 "$url" 2>/dev/null | tr -d '[:space:]'
  fi
}

# ── Drift Check ──

check_drift() {
  local target_dir="${1:-.}"
  if [[ -f "$ROOT_DIR/lib/freshness/track.sh" ]]; then
    # shellcheck source=../lib/freshness/track.sh
    source "$ROOT_DIR/lib/freshness/track.sh" 2>/dev/null || return 1
    local drift
    drift=$(freshness_check_drift "$target_dir" 2>/dev/null || echo "unknown")
    if [[ "$drift" == drifted:* ]]; then
      echo "DRIFT_DETECTED ${drift#drifted:}"
      return 0
    fi
  fi
  return 1
}

# ── Main ──

main() {
  # Respect disable flag
  is_check_disabled && exit 0

  local local_ver
  local_ver=$(local_version)

  # 1. Check cache first (fast path)
  local cached
  if cached=$(check_cache); then
    if [[ "$cached" == UPGRADE_AVAILABLE* ]]; then
      local remote_ver="${cached##* }"
      is_snoozed "$remote_ver" && exit 0
    fi
    echo "$cached"
    exit 0
  fi

  # 2. Fetch remote version
  local remote_ver
  remote_ver=$(fetch_remote_version)

  if [[ -z "$remote_ver" ]]; then
    # Network failed — check drift as fallback
    check_drift "${TARGET_DIR:-.}" || true
    exit 0
  fi

  # 3. Compare versions
  if version_lt "$local_ver" "$remote_ver"; then
    write_cache "UPGRADE_AVAILABLE $local_ver $remote_ver"
    if ! is_snoozed "$remote_ver"; then
      echo "UPGRADE_AVAILABLE $local_ver $remote_ver"
    fi
  else
    write_cache "UP_TO_DATE $local_ver $remote_ver"
    # Still check drift even if version is current
    check_drift "${TARGET_DIR:-.}" || echo "UP_TO_DATE"
  fi
}

main "$@"
