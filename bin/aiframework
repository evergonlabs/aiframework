#!/usr/bin/env bash
# aiframework — Universal Automation Bootstrap CLI
# Deterministic repo analysis + CLAUDE.md generation + verification
#
# Usage:
#   aiframework discover [--target <path>] [--output <path>]
#   aiframework generate [--manifest <path>] [--target <path>]
#   aiframework verify  [--target <path>] [--manifest <path>]
#   aiframework refresh [--target <path>]   # lightweight: re-discover + generate only if drift detected
#   aiframework run     [--target <path>]   # discover + generate + verify in sequence

set -euo pipefail

# Bash 4+ recommended but not required — core features work on bash 3.2+
if [[ ${BASH_VERSINFO[0]:-3} -lt 4 ]]; then
  echo "Note: bash 4+ recommended for best results. You have bash ${BASH_VERSION:-3.2}."
  echo "  macOS: brew install bash"
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$ROOT_DIR/lib"
TEMPLATES_DIR="$ROOT_DIR/templates"

# Cleanup trap — remove temp files on exit
_aiframework_cleanup() {
  if [[ -n "${_AIF_TMPDIR:-}" && -d "$_AIF_TMPDIR" && "$_AIF_TMPDIR" == /tmp/* ]]; then
    rm -rf "$_AIF_TMPDIR"
  fi
}
trap _aiframework_cleanup EXIT

# Dependency check — validate required tools are available
check_dependencies() {
  local missing=0

  if ! command -v jq &>/dev/null; then
    echo "ERROR: 'jq' is required but not installed."
    echo "  macOS:        brew install jq"
    echo "  Ubuntu/Debian: sudo apt-get install jq"
    echo "  Fedora:       sudo dnf install jq"
    missing=1
  fi

  if ! command -v git &>/dev/null; then
    echo "ERROR: 'git' is required but not installed."
    echo "  macOS:        xcode-select --install"
    echo "  Ubuntu/Debian: sudo apt-get install git"
    missing=1
  fi

  if [[ $missing -ne 0 ]]; then
    echo ""
    echo "Install missing dependencies and try again."
    exit 1
  fi
}

check_dependencies

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log_info()  { echo -e "${BLUE}[INFO]${NC}  $*"; }
log_ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*"; }
log_step()  { echo -e "${CYAN}[STEP]${NC}  ${BOLD}$*${NC}"; }

banner() {
  echo ""
  echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${BOLD}  aiframework — Universal Automation Bootstrap${NC}"
  echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
}

usage() {
  cat <<'EOF'
Usage: aiframework <command> [options]

Commands:
  discover    Scan a repo and produce manifest.json (deterministic, 100% coverage)
  generate    Read manifest.json and generate CLAUDE.md + all supporting files
  verify      Validate generated files against manifest (zero drift check)
  report      Generate a human-readable report of everything detected and generated
  refresh     Lightweight update: re-discover + regenerate only if drift detected
  index       Build code index for the target repo (standalone)
  run         Full pipeline: discover → generate → verify → report
  stats       Show cross-repo knowledge store statistics

Options:
  --target <path>      Target repo to analyze (default: current directory)
  --manifest <path>    Path to manifest.json (default: .aiframework/manifest.json)
  --output <path>      Output directory for manifest (default: .aiframework/)
  --dry-run            Show what would be generated without writing files
  --verbose            Show detailed scanner output
  --non-interactive    Skip all user prompts (set all user_context to null)
  --no-index           Skip the code index step during discover
  --help               Show this help

Note: Enhancement is done via the /aif-enhance skill in Claude Code — no API key needed.

Examples:
  aiframework discover --target /path/to/repo
  aiframework discover --target /path/to/repo --no-index
  aiframework generate --manifest .aiframework/manifest.json
  aiframework verify
  aiframework index --target /path/to/repo
  aiframework run --target /path/to/my-project
EOF
}

# Parse arguments
COMMAND=""
TARGET_DIR="."
MANIFEST_PATH=""
OUTPUT_DIR=""
DRY_RUN=false
VERBOSE=false
NON_INTERACTIVE=false
NO_INDEX=false

parse_args() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  # Handle --help/-h as first argument
  if [[ "$1" == "--help" || "$1" == "-h" || "$1" == "help" ]]; then
    usage
    exit 0
  fi

  COMMAND="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target)    TARGET_DIR="$2"; shift 2 ;;
      --manifest)  MANIFEST_PATH="$2"; shift 2 ;;
      --output)    OUTPUT_DIR="$2"; shift 2 ;;
      --dry-run)   DRY_RUN=true; shift ;;
      --verbose)   VERBOSE=true; shift ;;
      --non-interactive) NON_INTERACTIVE=true; shift ;;
      --no-index)  NO_INDEX=true; shift ;;
      --help|-h)   usage; exit 0 ;;
      *)           log_error "Unknown option: $1"; usage; exit 1 ;;
    esac
  done

  # Resolve paths
  TARGET_DIR="$(cd "$TARGET_DIR" 2>/dev/null && pwd)" || {
    log_error "Target directory does not exist: $TARGET_DIR"
    exit 1
  }

  if [[ -z "$OUTPUT_DIR" ]]; then
    OUTPUT_DIR="$TARGET_DIR/.aiframework"
  fi

  if [[ -z "$MANIFEST_PATH" ]]; then
    MANIFEST_PATH="$OUTPUT_DIR/manifest.json"
  fi
}

# Export for scanner/generator/validator modules
export TARGET_DIR MANIFEST_PATH OUTPUT_DIR DRY_RUN VERBOSE NON_INTERACTIVE
export NO_INDEX
export LIB_DIR TEMPLATES_DIR ROOT_DIR

# Knowledge store (cross-repo learning)
source "$LIB_DIR/knowledge/store.sh"

# Freshness tracking (drift detection)
source "$LIB_DIR/freshness/track.sh"

cmd_discover() {
  banner
  log_step "DISCOVER — Scanning repo at $TARGET_DIR"
  echo ""

  mkdir -p "$OUTPUT_DIR"

  # Source all scanners
  source "$LIB_DIR/scanners/identity.sh"
  source "$LIB_DIR/scanners/stack.sh"
  source "$LIB_DIR/scanners/commands.sh"
  source "$LIB_DIR/scanners/structure.sh"
  source "$LIB_DIR/scanners/ci.sh"
  source "$LIB_DIR/scanners/env.sh"
  source "$LIB_DIR/scanners/quality.sh"
  source "$LIB_DIR/scanners/domain.sh"
  source "$LIB_DIR/scanners/user_context.sh"
  source "$LIB_DIR/scanners/code_index.sh"
  source "$LIB_DIR/scanners/archetype.sh"
  source "$LIB_DIR/scanners/skill_suggest.sh"

  # Initialize manifest
  MANIFEST="{}"

  # Run each scanner — each appends to MANIFEST
  log_step "1/12 Project Identity"
  scan_identity

  log_step "2/12 Stack Detection"
  scan_stack

  log_step "3/12 Commands & Package Manager"
  scan_commands

  log_step "4/12 Directory Structure"
  scan_structure

  log_step "5/12 CI/CD & Deploy"
  scan_ci

  log_step "6/12 Environment Variables"
  scan_env

  log_step "7/12 Quality Tools"
  scan_quality

  log_step "8/12 Domain-Specific Concerns"
  scan_domain

  log_step "9/12 User Context"
  scan_user_context

  if [[ "$NO_INDEX" != "true" ]]; then
    log_step "10/12 Code Index"
    scan_code_index
  fi

  log_step "11/12 Archetype Detection"
  scan_archetype

  log_step "12/12 Skill Suggestions"
  scan_skill_suggestions

  # Add metadata
  MANIFEST=$(echo "$MANIFEST" | jq --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg ver "$(cat "$ROOT_DIR/VERSION")" \
    --arg target "$TARGET_DIR" \
    '. + {
      "_meta": {
        "generated_at": $ts,
        "aiframework_version": $ver,
        "target_dir": $target,
        "scanner": "aiframework/discover"
      }
    }')

  # Write manifest
  echo "$MANIFEST" | jq '.' > "$MANIFEST_PATH"

  # Save file hashes for drift detection
  freshness_save_hashes "$TARGET_DIR"

  # Record profile in knowledge store
  knowledge_record_profile "$MANIFEST"

  echo ""
  log_ok "Manifest written to $MANIFEST_PATH"
  log_info "$(echo "$MANIFEST" | jq '._meta' 2>/dev/null)"
  echo ""

  # Print summary
  echo -e "${BOLD}Discovery Summary:${NC}"
  echo "  Project:    $(echo "$MANIFEST" | jq -r '.identity.name // "unknown"')"
  echo "  Language:   $(echo "$MANIFEST" | jq -r '.stack.language // "unknown"')"
  echo "  Framework:  $(echo "$MANIFEST" | jq -r '.stack.framework // "none"')"
  echo "  Monorepo:   $(echo "$MANIFEST" | jq -r '.stack.is_monorepo // false')"
  echo "  Files:      $(echo "$MANIFEST" | jq -r '.structure.file_counts | to_entries | map("\(.key): \(.value)") | join(", ") // "none"' 2>/dev/null || echo "none")"
  echo "  CI:         $(echo "$MANIFEST" | jq -r '.ci.provider // "none"')"
  echo "  Env vars:   $(echo "$MANIFEST" | jq -r '.env.variables | length // 0' 2>/dev/null || echo "0")"
  echo "  Quality:    $(echo "$MANIFEST" | jq -r '[.quality | to_entries[] | select(.value.configured == true) | .key] | join(", ") // "none"' 2>/dev/null || echo "none")"
  echo ""
}

cmd_generate() {
  banner
  log_step "GENERATE — Building files from manifest"
  echo ""

  if [[ ! -f "$MANIFEST_PATH" ]]; then
    log_error "Manifest not found at $MANIFEST_PATH"
    log_info "Run 'aiframework discover' first"
    exit 1
  fi

  MANIFEST=$(cat "$MANIFEST_PATH")
  export MANIFEST

  # Load preserve module first — generators call its functions
  source "$LIB_DIR/generators/preserve.sh"
  _init_preserve

  source "$LIB_DIR/generators/claude_md.sh"
  source "$LIB_DIR/generators/hooks.sh"
  source "$LIB_DIR/generators/ci.sh"
  source "$LIB_DIR/generators/skills.sh"
  source "$LIB_DIR/generators/docs.sh"
  source "$LIB_DIR/generators/tracking.sh"
  source "$LIB_DIR/generators/vault.sh"
  source "$LIB_DIR/generators/vault_ingest.sh"

  local generated=0

  log_step "1/7 Generating CLAUDE.md"
  generate_claude_md && ((generated++)) || true

  log_step "2/7 Generating git hooks"
  generate_hooks && ((generated++)) || true

  log_step "3/7 Generating CI workflow"
  generate_ci && ((generated++)) || true

  log_step "4/7 Generating custom skills"
  generate_skills && ((generated++)) || true

  log_step "5/7 Generating documentation scaffold"
  generate_docs && ((generated++)) || true

  log_step "6/7 Generating tracking files"
  generate_tracking && ((generated++)) || true

  log_step "7/7 Generating agentic memory vault"
  generate_vault && ((generated++)) || true

  echo ""
  log_ok "Generated $generated/7 file groups"
  print_preserve_summary
  echo ""
}

cmd_verify() {
  banner
  log_step "VERIFY — Validating generated files"
  echo ""

  if [[ ! -f "$MANIFEST_PATH" ]]; then
    log_error "Manifest not found at $MANIFEST_PATH"
    exit 1
  fi

  MANIFEST=$(cat "$MANIFEST_PATH")
  export MANIFEST

  source "$LIB_DIR/validators/files.sh"
  source "$LIB_DIR/validators/consistency.sh"
  source "$LIB_DIR/validators/security.sh"
  source "$LIB_DIR/validators/quality_gate.sh"
  source "$LIB_DIR/validators/freshness.sh"

  local total_checks=0
  local passed=0
  local failed=0
  local warnings=0

  echo -e "${BOLD}┌──────────────────────────────┬──────────┬─────────────────────────────┐${NC}"
  echo -e "${BOLD}│ Check                        │ Status   │ Details                     │${NC}"
  echo -e "${BOLD}├──────────────────────────────┼──────────┼─────────────────────────────┤${NC}"

  # Run each validator
  validate_files
  validate_consistency
  validate_security
  validate_quality_gate
  validate_freshness

  echo -e "${BOLD}└──────────────────────────────┴──────────┴─────────────────────────────┘${NC}"
  echo ""
  echo -e "  ${GREEN}Passed:${NC} $passed  ${RED}Failed:${NC} $failed  ${YELLOW}Warnings:${NC} $warnings  Total: $total_checks"
  echo ""

  if [[ $failed -gt 0 ]]; then
    log_error "Verification FAILED — $failed issue(s) need fixing"
    exit 1
  else
    log_ok "Verification PASSED"
  fi
}

cmd_index() {
  banner
  log_step "INDEX — Building code index for $TARGET_DIR"
  echo ""
  mkdir -p "$OUTPUT_DIR"
  source "$LIB_DIR/scanners/code_index.sh"
  scan_code_index
  echo ""
  log_ok "Code index written to $OUTPUT_DIR/code-index.json"
}

cmd_stats() {
  banner
  log_step "STATS — Cross-repo knowledge store"
  echo ""
  knowledge_stats
  echo ""
}

cmd_report() {
  banner
  log_step "REPORT — Generating human-readable summary"
  echo ""

  if [[ ! -f "$MANIFEST_PATH" ]]; then
    log_error "Manifest not found at $MANIFEST_PATH"
    log_info "Run 'aiframework discover' first"
    exit 1
  fi

  MANIFEST=$(cat "$MANIFEST_PATH")
  export MANIFEST

  source "$LIB_DIR/validators/files.sh"
  source "$LIB_DIR/validators/consistency.sh"
  source "$LIB_DIR/validators/security.sh"
  source "$LIB_DIR/validators/quality_gate.sh"
  source "$LIB_DIR/validators/freshness.sh"
  source "$LIB_DIR/generators/report.sh"

  generate_report
  echo ""
  log_info "Open .aiframework/report.md to review what was detected and generated"
  log_info "If anything is wrong, run /aif-feedback in Claude Code"
}

cmd_refresh() {
  banner
  log_step "REFRESH — Checking for drift and updating if needed"
  echo ""

  local drift_result
  drift_result=$(freshness_check_drift "$TARGET_DIR")

  if [[ "$drift_result" == "clean" ]]; then
    log_ok "No drift detected — files are up to date"
    return 0
  elif [[ "$drift_result" == "no-baseline" ]]; then
    log_warn "No baseline found — running full discover"
    cmd_discover
    cmd_generate
    return 0
  else
    local drifted_files="${drift_result#drifted:}"
    log_warn "Drift detected in:$drifted_files"
    log_info "Re-running discover + generate..."
    echo ""
    cmd_discover
    echo ""
    cmd_generate
    return 0
  fi
}

cmd_run() {
  cmd_discover

  # Analysis summary (A20)
  echo ""
  log_step "Analysis Summary"
  echo "  Project: $(echo "$MANIFEST" | jq -r '.identity.name')"
  echo "  Language: $(echo "$MANIFEST" | jq -r '.stack.language')"
  echo "  Framework: $(echo "$MANIFEST" | jq -r '.stack.framework // "none"')"
  echo "  Domains: $(echo "$MANIFEST" | jq -r '.domain.detected_domains | length' 2>/dev/null || echo 0)"
  echo "  Env vars: $(echo "$MANIFEST" | jq '.env.variables | length' 2>/dev/null || echo 0)"
  echo "  CI: $(echo "$MANIFEST" | jq -r '.ci.provider // "none"')"
  echo ""

  if [[ "$NON_INTERACTIVE" != "true" ]] && [[ -t 0 ]]; then
    read -p "  Proceed with generation? [Y/n] " confirm
    if [[ "$confirm" =~ ^[Nn] ]]; then
      log_warn "Aborted by user"
      return 1
    fi
  fi

  echo ""
  echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  cmd_generate
  echo ""
  echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  cmd_verify
  echo ""
  echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  cmd_report
}

# Main
parse_args "$@"

case "$COMMAND" in
  discover)  cmd_discover ;;
  generate)  cmd_generate ;;
  verify)    cmd_verify ;;
  report)    cmd_report ;;
  refresh)   cmd_refresh ;;
  index)     cmd_index ;;
  stats)     cmd_stats ;;
  run)       cmd_run ;;
  *)         log_error "Unknown command: $COMMAND"; usage; exit 1 ;;
esac
