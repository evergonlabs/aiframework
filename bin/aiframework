#!/usr/bin/env bash
# aiframework — Universal Automation Bootstrap CLI
# Deterministic repo analysis + CLAUDE.md generation + verification
#
# Usage:
#   aiframework discover [--target <path>] [--output <path>]
#   aiframework generate [--manifest <path>] [--target <path>]
#   aiframework verify  [--target <path>] [--manifest <path>]
#   aiframework refresh [--target <path>]   # lightweight: re-discover + generate only if drift detected
#   aiframework run     [--target <path>]   # discover + generate + verify in sequence

set -euo pipefail

# Bash 4+ recommended but not required — core features work on bash 3.2+
if [[ ${BASH_VERSINFO[0]:-3} -lt 4 ]]; then
  echo "Note: bash 4+ recommended for best results. You have bash ${BASH_VERSION:-3.2}."
  echo "  macOS: brew install bash"
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$ROOT_DIR/lib"
TEMPLATES_DIR="$ROOT_DIR/templates"

# Create a project-specific temp directory for this run
_AIF_TMPDIR=$(mktemp -d /tmp/aiframework.XXXXXX 2>/dev/null || mktemp -d)
export _AIF_TMPDIR

# Cleanup trap — remove temp files on exit
_aiframework_cleanup() {
  if [[ -n "${_AIF_TMPDIR:-}" && -d "$_AIF_TMPDIR" && "$_AIF_TMPDIR" == /tmp/* ]]; then
    rm -rf "$_AIF_TMPDIR"
  fi
}
trap _aiframework_cleanup EXIT

# Portable timeout wrapper — falls back to bare execution on stock macOS
_aif_timeout() {
  local secs="$1"; shift
  if command -v timeout &>/dev/null; then
    timeout "$secs" "$@"
  else
    "$@"
  fi
}

# Dependency check — validate required tools are available
check_dependencies() {
  local missing=0

  if ! command -v jq &>/dev/null; then
    echo "ERROR: 'jq' is required but not installed."
    echo "  macOS:        brew install jq"
    echo "  Ubuntu/Debian: sudo apt-get install jq"
    echo "  Fedora:       sudo dnf install jq"
    missing=1
  fi

  if ! command -v git &>/dev/null; then
    echo "ERROR: 'git' is required but not installed."
    echo "  macOS:        xcode-select --install"
    echo "  Ubuntu/Debian: sudo apt-get install git"
    missing=1
  fi

  if [[ $missing -ne 0 ]]; then
    echo ""
    echo "Install missing dependencies and try again."
    exit 1
  fi
}

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# Timing
_AIF_PHASE_START=0
_aif_timer_start() { _AIF_PHASE_START=$SECONDS; }
_aif_timer_elapsed() {
  local elapsed=$(( SECONDS - _AIF_PHASE_START ))
  if [[ $elapsed -lt 1 ]]; then
    printf "0.%ss" "$(( (SECONDS * 10 - _AIF_PHASE_START * 10) % 10 ))"
  else
    printf "%s.%ss" "$elapsed" "$(( (SECONDS * 10 - _AIF_PHASE_START * 10) % 10 ))"
  fi
}

# Step counter for progress tracking
_AIF_STEP=0
_AIF_STEP_TOTAL=0

log_info()  { echo -e "  ${BLUE}ℹ${NC}  $*"; }
log_ok()    { echo -e "  ${GREEN}✓${NC}  $*"; }
log_warn()  { echo -e "  ${YELLOW}⚠${NC}  $*"; }
log_error() { echo -e "  ${RED}✗${NC}  $*"; }

log_step() {
  _AIF_STEP=$((_AIF_STEP + 1))
  if [[ $_AIF_STEP_TOTAL -gt 0 ]]; then
    local pct=$(( _AIF_STEP * 100 / _AIF_STEP_TOTAL ))
    local filled=$(( pct / 5 ))
    local empty=$(( 20 - filled ))
    local bar=""
    local i
    for ((i=0; i<filled; i++)); do bar+="█"; done
    for ((i=0; i<empty; i++)); do bar+="░"; done
    echo -e "  ${CYAN}├─${NC} ${DIM}[${_AIF_STEP}/${_AIF_STEP_TOTAL}]${NC} ${BOLD}$*${NC} ${DIM}${bar}${NC}"
  else
    echo -e "  ${CYAN}├─${NC} ${BOLD}$*${NC}"
  fi
}

log_phase() {
  local name="$1"
  local count="${2:-}"
  _AIF_STEP=0
  _AIF_STEP_TOTAL=0
  _aif_timer_start
  echo ""
  if [[ -n "$count" ]]; then
    _AIF_STEP_TOTAL=$count
    echo -e "  ${CYAN}┌─${NC} ${WHITE}${BOLD}${name}${NC} ${DIM}(${count} steps)${NC}"
  else
    echo -e "  ${CYAN}┌─${NC} ${WHITE}${BOLD}${name}${NC}"
  fi
  echo -e "  ${CYAN}│${NC}"
}

log_phase_done() {
  local elapsed
  elapsed=$(_aif_timer_elapsed)
  echo -e "  ${CYAN}│${NC}"
  echo -e "  ${CYAN}└─${NC} ${GREEN}done${NC} ${DIM}${elapsed}${NC}"
}

banner() {
  local version
  version="$(cat "$ROOT_DIR/VERSION" 2>/dev/null | tr -d '[:space:]')"
  echo ""
  echo -e "  ${CYAN}╔═══════════════════════════════════════════════╗${NC}"
  echo -e "  ${CYAN}║${NC}  ${WHITE}${BOLD}▄▀█ █ █▀▀ █▀█ ▄▀█ █▀▄▀█ █▀▀${NC}              ${CYAN}║${NC}"
  echo -e "  ${CYAN}║${NC}  ${WHITE}${BOLD}█▀█ █ █▀  █▀▄ █▀█ █ ▀ █ ██▄${NC}              ${CYAN}║${NC}"
  echo -e "  ${CYAN}║${NC}  ${DIM}Universal Automation Bootstrap${NC}  ${MAGENTA}v${version}${NC}   ${CYAN}║${NC}"
  echo -e "  ${CYAN}╚═══════════════════════════════════════════════╝${NC}"
  echo ""
}

# Completion summary box
_aif_summary() {
  local project="$1" stack="$2" files="$3" checks="$4" failed="$5" report="$6"
  local status_icon status_text status_color
  if [[ "$failed" -eq 0 ]]; then
    status_icon="✓"; status_text="Pipeline Complete"; status_color="$GREEN"
  else
    status_icon="⚠"; status_text="Pipeline Complete (with warnings)"; status_color="$YELLOW"
  fi
  echo ""
  echo -e "  ${CYAN}╔═══════════════════════════════════════════════╗${NC}"
  echo -e "  ${CYAN}║${NC}  ${status_color}${BOLD}${status_icon} ${status_text}${NC}$(printf '%*s' $((27 - ${#status_text})) '')${CYAN}║${NC}"
  echo -e "  ${CYAN}╠═══════════════════════════════════════════════╣${NC}"
  echo -e "  ${CYAN}║${NC}  ${DIM}Project:${NC}  ${BOLD}${project}${NC}$(printf '%*s' $((36 - ${#project})) '')${CYAN}║${NC}"
  echo -e "  ${CYAN}║${NC}  ${DIM}Stack:${NC}    ${stack}$(printf '%*s' $((36 - ${#stack})) '')${CYAN}║${NC}"
  echo -e "  ${CYAN}║${NC}  ${DIM}Files:${NC}    ${files} generated$(printf '%*s' $((26 - ${#files})) '')${CYAN}║${NC}"
  echo -e "  ${CYAN}║${NC}  ${DIM}Checks:${NC}   ${GREEN}${checks} passed${NC}, ${RED}${failed} failed${NC}$(printf '%*s' $((22 - ${#checks} - ${#failed})) '')${CYAN}║${NC}"
  echo -e "  ${CYAN}║${NC}  ${DIM}Report:${NC}   ${report}$(printf '%*s' $((36 - ${#report})) '')${CYAN}║${NC}"
  echo -e "  ${CYAN}╚═══════════════════════════════════════════════╝${NC}"
  echo ""
}

usage() {
  cat <<'EOF'
Usage: aiframework <command> [options]

Commands:
  discover    Scan a repo and produce manifest.json (deterministic, 100% coverage)
  generate    Read manifest.json and generate CLAUDE.md + all supporting files
  verify      Validate generated files against manifest (zero drift check)
  report      Generate a human-readable report of everything detected and generated
  refresh     Lightweight update: re-discover + regenerate only if drift detected
  index       Build code index for the target repo (standalone)
  run         Full pipeline: discover → generate → verify → report
  stats       Show cross-repo knowledge store statistics

Options:
  --target <path>      Target repo to analyze (default: current directory)
  --manifest <path>    Path to manifest.json (default: .aiframework/manifest.json)
  --output <path>      Output directory for manifest (default: .aiframework/)
  --dry-run            Show what would be generated without writing files
  --verbose            Show detailed scanner output
  --non-interactive    Skip all user prompts (set all user_context to null)
  --no-index           Skip the code index step during discover
  --help               Show this help

Note: Enhancement is done via the /aif-enhance skill in Claude Code — no API key needed.

Examples:
  aiframework discover --target /path/to/repo
  aiframework discover --target /path/to/repo --no-index
  aiframework generate --manifest .aiframework/manifest.json
  aiframework verify
  aiframework index --target /path/to/repo
  aiframework run --target /path/to/my-project
EOF
}

# Parse arguments
COMMAND=""
TARGET_DIR="."
MANIFEST_PATH=""
OUTPUT_DIR=""
DRY_RUN=false
VERBOSE=false
NON_INTERACTIVE=false
NO_INDEX=false

parse_args() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  # Handle --help/-h as first argument
  if [[ "$1" == "--help" || "$1" == "-h" || "$1" == "help" ]]; then
    usage
    exit 0
  fi

  # Handle --version/-v
  if [[ "$1" == "--version" || "$1" == "-v" ]]; then
    cat "$ROOT_DIR/VERSION"
    exit 0
  fi

  COMMAND="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target)    TARGET_DIR="$2"; shift 2 ;;
      --manifest)  MANIFEST_PATH="$2"; shift 2 ;;
      --output)    OUTPUT_DIR="$2"; shift 2 ;;
      --dry-run)   DRY_RUN=true; shift ;;
      --verbose)   VERBOSE=true; shift ;;
      --non-interactive) NON_INTERACTIVE=true; shift ;;
      --no-index)  NO_INDEX=true; shift ;;
      --tier)      AIF_CLI_TIER="$2"; shift 2 ;;
      --help|-h)   usage; exit 0 ;;
      *)           log_error "Unknown option: $1"; usage; exit 1 ;;
    esac
  done

  # Resolve paths
  TARGET_DIR="$(cd "$TARGET_DIR" 2>/dev/null && pwd)" || {
    log_error "Target directory does not exist: $TARGET_DIR"
    exit 1
  }

  if [[ -z "$OUTPUT_DIR" ]]; then
    OUTPUT_DIR="$TARGET_DIR/.aiframework"
  fi

  if [[ -z "$MANIFEST_PATH" ]]; then
    MANIFEST_PATH="$OUTPUT_DIR/manifest.json"
  fi
}

# Export for scanner/generator/validator modules
export TARGET_DIR MANIFEST_PATH OUTPUT_DIR DRY_RUN VERBOSE NON_INTERACTIVE
export NO_INDEX
export LIB_DIR TEMPLATES_DIR ROOT_DIR

# Knowledge store (cross-repo learning)
source "$LIB_DIR/knowledge/store.sh"

# Freshness tracking (drift detection)
source "$LIB_DIR/freshness/track.sh"

cmd_discover() {
  banner
  log_phase "DISCOVER" 13
  log_info "Scanning repo at ${BOLD}$TARGET_DIR${NC}"
  echo -e "  ${CYAN}│${NC}"

  mkdir -p "$OUTPUT_DIR"

  # Source all scanners
  source "$LIB_DIR/scanners/identity.sh"
  source "$LIB_DIR/scanners/stack.sh"
  source "$LIB_DIR/scanners/commands.sh"
  source "$LIB_DIR/scanners/structure.sh"
  source "$LIB_DIR/scanners/ci.sh"
  source "$LIB_DIR/scanners/env.sh"
  source "$LIB_DIR/scanners/quality.sh"
  source "$LIB_DIR/scanners/domain.sh"
  source "$LIB_DIR/scanners/user_context.sh"
  source "$LIB_DIR/scanners/code_index.sh"
  source "$LIB_DIR/scanners/archetype.sh"
  source "$LIB_DIR/scanners/skill_suggest.sh"
  source "$LIB_DIR/scanners/sheal.sh"

  # Initialize manifest
  MANIFEST="{}"

  # Run each scanner — each appends to MANIFEST
  log_step "Project Identity"
  scan_identity

  log_step "Stack Detection"
  scan_stack

  log_step "Commands & Package Manager"
  scan_commands

  log_step "Directory Structure"
  scan_structure

  log_step "CI/CD & Deploy"
  scan_ci

  log_step "Environment Variables"
  scan_env

  log_step "Quality Tools"
  scan_quality

  log_step "Domain-Specific Concerns"
  scan_domain

  log_step "User Context"
  scan_user_context

  if [[ "$NO_INDEX" != "true" ]]; then
    log_step "Code Index"
    scan_code_index
  else
    _AIF_STEP=$((_AIF_STEP + 1))
    echo -e "  ${CYAN}├─${NC} ${DIM}[${_AIF_STEP}/${_AIF_STEP_TOTAL}]${NC} ${DIM}Code Index (skipped)${NC}"
  fi

  log_step "Archetype Detection"
  scan_archetype

  log_step "Skill Suggestions"
  scan_skill_suggestions

  log_step "Sheal Integration"
  scan_sheal || true

  log_phase_done

  # Add metadata
  MANIFEST=$(echo "$MANIFEST" | jq --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg ver "$(cat "$ROOT_DIR/VERSION")" \
    --arg target "$TARGET_DIR" \
    '. + {
      "_meta": {
        "generated_at": $ts,
        "aiframework_version": $ver,
        "target_dir": $target,
        "scanner": "aiframework/discover"
      }
    }')

  # Write manifest
  echo "$MANIFEST" | jq '.' > "$MANIFEST_PATH"

  # Save file hashes for drift detection
  freshness_save_hashes "$TARGET_DIR"

  # Record profile in knowledge store
  knowledge_record_profile "$MANIFEST"

  echo ""
  log_ok "Manifest written to ${BOLD}$MANIFEST_PATH${NC}"
  echo ""
}

cmd_generate() {
  banner

  if [[ ! -f "$MANIFEST_PATH" ]]; then
    log_error "Manifest not found at $MANIFEST_PATH"
    log_info "Run 'aiframework discover' first"
    exit 1
  fi

  MANIFEST=$(cat "$MANIFEST_PATH")
  export MANIFEST

  # Load config + resolve tier
  source "$LIB_DIR/config.sh"
  load_config
  resolve_tier "${AIF_CLI_TIER:-}"

  # Count total generators based on tier
  local total_steps=2  # CLAUDE.md + AGENTS.md always
  tier_includes "cursor" && format_enabled "cursor" && total_steps=$((total_steps + 1))
  tier_includes "hooks" && total_steps=$((total_steps + 1))
  tier_includes "ci" && total_steps=$((total_steps + 1))
  tier_includes "skills" && total_steps=$((total_steps + 1))
  # Sheal integration adds a step when installed and tier includes skills
  local _sheal_installed
  _sheal_installed=$(echo "$MANIFEST" | jq -r '.sheal.installed // false' 2>/dev/null)
  [[ "$_sheal_installed" == "true" ]] && tier_includes "skills" && total_steps=$((total_steps + 1))
  tier_includes "docs" && total_steps=$((total_steps + 1))
  tier_includes "tracking" && total_steps=$((total_steps + 1))
  tier_includes "vault-memory" && total_steps=$((total_steps + 1))

  log_phase "GENERATE" "$total_steps"

  # Load preserve module first — generators call its functions
  source "$LIB_DIR/generators/preserve.sh"
  _init_preserve

  source "$LIB_DIR/generators/claude_md.sh"
  source "$LIB_DIR/generators/agents_md.sh"
  source "$LIB_DIR/generators/cursor_rules.sh"
  source "$LIB_DIR/generators/hooks.sh"
  source "$LIB_DIR/generators/ci.sh"
  source "$LIB_DIR/generators/skills.sh"
  source "$LIB_DIR/generators/docs.sh"
  source "$LIB_DIR/generators/tracking.sh"
  source "$LIB_DIR/generators/vault.sh"
  source "$LIB_DIR/generators/vault_ingest.sh"
  source "$LIB_DIR/generators/sheal.sh"

  local generated=0

  # CLAUDE.md — always generated
  if format_enabled "claude"; then
    log_step "Generating CLAUDE.md"
    generate_claude_md && generated=$((generated + 1)) || true
  fi

  # AGENTS.md — always generated
  if format_enabled "agents"; then
    log_step "Generating AGENTS.md"
    generate_agents_md && generated=$((generated + 1)) || true
  fi

  # .cursorrules — standard tier+
  if tier_includes "cursor" && format_enabled "cursor"; then
    log_step "Generating .cursorrules"
    generate_cursor_rules && generated=$((generated + 1)) || true
  fi

  # Git hooks — standard tier+
  if tier_includes "hooks"; then
    log_step "Generating git hooks"
    generate_hooks && generated=$((generated + 1)) || true
  fi

  # CI workflow — standard tier+
  if tier_includes "ci"; then
    log_step "Generating CI workflow"
    generate_ci && generated=$((generated + 1)) || true
  fi

  # Custom skills — standard tier+
  if tier_includes "skills"; then
    log_step "Generating custom skills"
    generate_skills && generated=$((generated + 1)) || true
  fi

  # Sheal integration — when installed and tier includes skills
  if [[ "$_sheal_installed" == "true" ]] && tier_includes "skills"; then
    log_step "Generating sheal integration"
    generate_sheal && generated=$((generated + 1)) || true
  fi

  # Documentation scaffold — full tier+
  if tier_includes "docs"; then
    log_step "Generating documentation scaffold"
    generate_docs && generated=$((generated + 1)) || true
  fi

  # Tracking files — full tier+
  if tier_includes "tracking"; then
    log_step "Generating tracking files"
    generate_tracking && generated=$((generated + 1)) || true
  fi

  # Vault — full tier+ (memory), enterprise (full)
  if tier_includes "vault-memory"; then
    log_step "Generating agentic memory vault"
    generate_vault && generated=$((generated + 1)) || true
  fi

  log_phase_done

  echo ""
  log_ok "Generated ${BOLD}$generated/$total_steps${NC} file groups (tier: ${AIF_RESOLVED_TIER})"
  print_preserve_summary
  echo ""
}

cmd_verify() {
  banner
  log_phase "VERIFY"

  if [[ ! -f "$MANIFEST_PATH" ]]; then
    log_error "Manifest not found at $MANIFEST_PATH"
    exit 1
  fi

  MANIFEST=$(cat "$MANIFEST_PATH")
  export MANIFEST

  source "$LIB_DIR/validators/files.sh"
  source "$LIB_DIR/validators/consistency.sh"
  source "$LIB_DIR/validators/security.sh"
  source "$LIB_DIR/validators/quality_gate.sh"
  source "$LIB_DIR/validators/freshness.sh"

  local total_checks=0
  local passed=0
  local failed=0
  local warnings=0

  echo -e "  ${CYAN}│${NC}"
  echo -e "  ${CYAN}│${NC}  ${BOLD}┌──────────────────────────────┬──────────┬─────────────────────────────┐${NC}"
  echo -e "  ${CYAN}│${NC}  ${BOLD}│ Check                        │ Status   │ Details                     │${NC}"
  echo -e "  ${CYAN}│${NC}  ${BOLD}├──────────────────────────────┼──────────┼─────────────────────────────┤${NC}"

  # Run each validator
  validate_files
  validate_consistency
  validate_security
  validate_quality_gate
  validate_freshness

  # Optional sheal runtime checks (non-blocking)
  if command -v sheal &>/dev/null; then
    local _sheal_result _sheal_status
    _sheal_result=$(sheal check --format json --project "$TARGET_DIR" --skip tests 2>/dev/null) || true
    if [[ -n "$_sheal_result" ]]; then
      _sheal_status=$(echo "$_sheal_result" | jq -r '.status // "unknown"' 2>/dev/null || echo "unknown")
      total_checks=$((total_checks + 1))
      if [[ "$_sheal_status" == "healthy" || "$_sheal_status" == "pass" ]]; then
        passed=$((passed + 1))
        printf "  ${CYAN}│${NC}  ${BOLD}│${NC} %-28s ${BOLD}│${NC} ${GREEN}%-8s${NC} ${BOLD}│${NC} %-27s ${BOLD}│${NC}\n" "Sheal Runtime" "PASS" "Runtime health OK"
      else
        warnings=$((warnings + 1))
        printf "  ${CYAN}│${NC}  ${BOLD}│${NC} %-28s ${BOLD}│${NC} ${YELLOW}%-8s${NC} ${BOLD}│${NC} %-27s ${BOLD}│${NC}\n" "Sheal Runtime" "WARN" "Check: sheal check"
      fi
    fi
  fi

  echo -e "  ${CYAN}│${NC}  ${BOLD}└──────────────────────────────┴──────────┴─────────────────────────────┘${NC}"
  echo -e "  ${CYAN}│${NC}"
  echo -e "  ${CYAN}│${NC}  ${GREEN}Passed:${NC} $passed  ${RED}Failed:${NC} $failed  ${YELLOW}Warnings:${NC} $warnings  ${DIM}Total: $total_checks${NC}"

  # Export counters for cmd_run summary
  _AIF_VERIFY_PASSED=$passed
  _AIF_VERIFY_FAILED=$failed

  log_phase_done

  echo ""
  if [[ $failed -gt 0 ]]; then
    log_error "Verification FAILED — $failed issue(s) need fixing"
    exit 1
  else
    log_ok "Verification ${BOLD}PASSED${NC}"
  fi
}

cmd_index() {
  banner
  log_phase "INDEX"
  log_info "Building code index for ${BOLD}$TARGET_DIR${NC}"
  mkdir -p "$OUTPUT_DIR"
  source "$LIB_DIR/scanners/code_index.sh"
  scan_code_index
  log_phase_done
  echo ""
  log_ok "Code index written to ${BOLD}$OUTPUT_DIR/code-index.json${NC}"
}

cmd_stats() {
  banner
  log_phase "STATS"
  knowledge_stats
  log_phase_done
  echo ""
}

cmd_report() {
  banner
  log_phase "REPORT"

  if [[ ! -f "$MANIFEST_PATH" ]]; then
    log_error "Manifest not found at $MANIFEST_PATH"
    log_info "Run 'aiframework discover' first"
    exit 1
  fi

  MANIFEST=$(cat "$MANIFEST_PATH")
  export MANIFEST

  source "$LIB_DIR/validators/files.sh"
  source "$LIB_DIR/validators/consistency.sh"
  source "$LIB_DIR/validators/security.sh"
  source "$LIB_DIR/validators/quality_gate.sh"
  source "$LIB_DIR/validators/freshness.sh"
  source "$LIB_DIR/generators/report.sh"

  generate_report
  log_phase_done
  echo ""
  log_info "Open ${BOLD}.aiframework/report.md${NC} to review what was detected and generated"
  log_info "If anything is wrong, run ${BOLD}/aif-feedback${NC} in Claude Code"
}

cmd_refresh() {
  banner
  log_phase "REFRESH"
  log_info "Checking for drift..."

  local drift_result
  drift_result=$(freshness_check_drift "$TARGET_DIR")

  if [[ "$drift_result" == "clean" ]]; then
    log_phase_done
    echo ""
    log_ok "No drift detected — files are up to date"
    return 0
  elif [[ "$drift_result" == "no-baseline" ]]; then
    log_warn "No baseline found — running full discover"
    log_phase_done
    cmd_discover
    cmd_generate
    return 0
  else
    local drifted_files="${drift_result#drifted:}"
    log_warn "Drift detected in:$drifted_files"
    log_info "Re-running discover + generate..."
    log_phase_done
    echo ""
    cmd_discover
    echo ""
    cmd_generate
    _write_refresh_notice "$drifted_files"
    return 0
  fi
}

_write_refresh_notice() {
  local drifted_files="${1:-}"
  local notice_file="$OUTPUT_DIR/last-refresh.json"
  local now
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  local user
  user=$(git config user.name 2>/dev/null || echo "unknown")
  cat > "$notice_file" << EOF
{
  "refreshed_at": "$now",
  "refreshed_by": "$user",
  "drifted_files": "$drifted_files",
  "version": "$(cat "$ROOT_DIR/VERSION" 2>/dev/null || echo "unknown")"
}
EOF
}

cmd_run() {
  local _run_start=$SECONDS

  cmd_discover

  # Analysis summary (A20)
  echo ""
  echo -e "  ${CYAN}┌─${NC} ${WHITE}${BOLD}ANALYSIS SUMMARY${NC}"
  echo -e "  ${CYAN}│${NC}"
  echo -e "  ${CYAN}│${NC}  ${DIM}Project:${NC}    ${BOLD}$(echo "$MANIFEST" | jq -r '.identity.name')${NC}"
  echo -e "  ${CYAN}│${NC}  ${DIM}Language:${NC}   $(echo "$MANIFEST" | jq -r '.stack.language')"
  echo -e "  ${CYAN}│${NC}  ${DIM}Framework:${NC} $(echo "$MANIFEST" | jq -r '.stack.framework // "none"')"
  echo -e "  ${CYAN}│${NC}  ${DIM}Domains:${NC}   $(echo "$MANIFEST" | jq -r '.domain.detected_domains | length' 2>/dev/null || echo 0)"
  echo -e "  ${CYAN}│${NC}  ${DIM}Env vars:${NC}  $(echo "$MANIFEST" | jq '.env.variables | length' 2>/dev/null || echo 0)"
  echo -e "  ${CYAN}│${NC}  ${DIM}CI:${NC}        $(echo "$MANIFEST" | jq -r '.ci.provider // "none"')"
  echo -e "  ${CYAN}│${NC}"
  echo -e "  ${CYAN}└─${NC}"
  echo ""

  if [[ "$NON_INTERACTIVE" != "true" ]] && [[ -t 0 ]]; then
    read -p "  Proceed with generation? [Y/n] " confirm
    if [[ "$confirm" =~ ^[Nn] ]]; then
      log_warn "Aborted by user"
      return 1
    fi
  fi

  cmd_generate
  cmd_verify
  cmd_report
  _write_refresh_notice "full-run"

  # Completion summary
  local _run_elapsed=$(( SECONDS - _run_start ))
  local _proj _stack _lang _fw _files_gen _checks_passed _checks_failed
  _proj=$(echo "$MANIFEST" | jq -r '.identity.name // "unknown"')
  _lang=$(echo "$MANIFEST" | jq -r '.stack.language // "unknown"')
  _fw=$(echo "$MANIFEST" | jq -r '.stack.framework // ""')
  if [[ -n "$_fw" && "$_fw" != "null" && "$_fw" != "none" ]]; then
    _stack="${_lang} / ${_fw}"
  else
    _stack="${_lang}"
  fi
  _files_gen="${generated:-7}"
  _checks_passed="${_AIF_VERIFY_PASSED:-0}"
  _checks_failed="${_AIF_VERIFY_FAILED:-0}"

  _aif_summary "$_proj" "$_stack" "$_files_gen" "$_checks_passed" "$_checks_failed" ".aiframework/report.md"
  echo -e "  ${DIM}Total time: ${_run_elapsed}s${NC}"
  echo ""
}

# Main
parse_args "$@"

# Check dependencies only when actually running a command (not for --help/--version)
check_dependencies

case "$COMMAND" in
  discover)  cmd_discover ;;
  generate)  cmd_generate ;;
  verify)    cmd_verify ;;
  report)    cmd_report ;;
  refresh)   cmd_refresh ;;
  index)     cmd_index ;;
  stats)     cmd_stats ;;
  run)       cmd_run ;;
  *)         log_error "Unknown command: $COMMAND"; usage; exit 1 ;;
esac
