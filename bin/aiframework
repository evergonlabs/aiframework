#!/usr/bin/env bash
# aiframework — Universal Automation Bootstrap CLI
# Deterministic repo analysis + CLAUDE.md generation + verification
#
# Usage:
#   aiframework discover [--target <path>] [--output <path>]
#   aiframework generate [--manifest <path>] [--target <path>]
#   aiframework verify  [--target <path>] [--manifest <path>]
#   aiframework refresh [--target <path>]   # lightweight: re-discover + generate only if drift detected
#   aiframework run     [--target <path>]   # discover + generate + verify in sequence

set -euo pipefail

# Bash 4+ recommended but not required — core features work on bash 3.2+
if [[ ${BASH_VERSINFO[0]:-3} -lt 4 ]]; then
  echo "Note: bash 4+ recommended for best results. You have bash ${BASH_VERSION:-3.2}."
  echo "  macOS: brew install bash"
fi

# Resolve through symlinks to find the real install directory
_AIF_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$_AIF_SOURCE" ]]; do
  _AIF_SOURCE="$(readlink "$_AIF_SOURCE")"
  # Handle relative symlinks
  [[ "$_AIF_SOURCE" != /* ]] && _AIF_SOURCE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$_AIF_SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$_AIF_SOURCE")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$ROOT_DIR/lib"
TEMPLATES_DIR="$ROOT_DIR/templates"

# Create a project-specific temp directory for this run
_AIF_TMPDIR=$(mktemp -d /tmp/aiframework.XXXXXX 2>/dev/null || mktemp -d)
export _AIF_TMPDIR

# Cleanup trap — remove temp files on exit
_aiframework_cleanup() {
  if [[ -n "${_AIF_TMPDIR:-}" && -d "$_AIF_TMPDIR" && "$_AIF_TMPDIR" == /tmp/* ]]; then
    rm -rf "$_AIF_TMPDIR"
  fi
}
trap _aiframework_cleanup EXIT

# Cross-platform timeout wrapper
# Priority: GNU timeout → gtimeout (Homebrew) → bash-native background+kill
_aif_timeout() {
  local secs="$1"; shift
  if command -v timeout &>/dev/null; then
    timeout "$secs" "$@"
  elif command -v gtimeout &>/dev/null; then
    gtimeout "$secs" "$@"
  else
    # Pure bash fallback — works on any platform (macOS, Linux, WSL, Git Bash)
    "$@" &
    local pid=$!
    (
      sleep "$secs"
      kill "$pid" 2>/dev/null
    ) &
    local watcher=$!
    wait "$pid" 2>/dev/null
    local exit_code=$?
    kill "$watcher" 2>/dev/null
    wait "$watcher" 2>/dev/null
    return $exit_code
  fi
}
export -f _aif_timeout

# Platform detection — used for OS-specific behavior
_AIF_PLATFORM="unknown"
case "$(uname -s 2>/dev/null)" in
  Darwin*)  _AIF_PLATFORM="macos" ;;
  Linux*)   _AIF_PLATFORM="linux" ;;
  MINGW*|MSYS*|CYGWIN*) _AIF_PLATFORM="windows" ;;
  *)        _AIF_PLATFORM="unknown" ;;
esac
export _AIF_PLATFORM

# ── Anonymous telemetry (opt-out via ~/.aiframework/config: telemetry: false) ──
#
# What we collect:
#   - Event type (run, discover, generate, verify, refresh, upgrade, error)
#   - Version, OS, bash version, Python version
#   - Anonymous machine ID (SHA-256 of hostname:user — not reversible)
#   - Pipeline outcomes: language, framework, archetype, scanners/generators count
#   - Errors: error message, phase where it happened (NO file paths, NO code)
#   - Integration status: sheal installed?, gstack installed?, vault pages count
#   - Timing: how long each phase took
#
# What we NEVER collect:
#   - Source code, file contents, file paths, project names
#   - Personal data, usernames, hostnames, IP addresses
#   - Git history, commit messages, branch names
#
_AIF_TELEMETRY_ENDPOINT="https://telemetry.evergonlabs.com/v1/event"

# Accumulator for errors during the session
_AIF_TELEMETRY_ERRORS=""

_aif_telemetry_enabled() {
  local config="${HOME}/.aiframework/config"
  [[ -f "$config" ]] && grep -q 'telemetry: false' "$config" 2>/dev/null && return 1
  return 0
}

# Build the base payload that's common to all events
_aif_telemetry_base() {
  local version
  version="$(cat "$ROOT_DIR/VERSION" 2>/dev/null | tr -d '[:space:]')"
  local machine_id
  machine_id=$(echo "${HOSTNAME:-unknown}:${USER:-unknown}" | shasum -a 256 2>/dev/null | cut -d' ' -f1 || echo "unknown")
  local python_version
  python_version=$(python3 --version 2>/dev/null | awk '{print $2}' || echo "none")
  local jq_version
  jq_version=$(jq --version 2>/dev/null | sed 's/jq-//' || echo "none")
  local has_sheal="false"
  command -v sheal &>/dev/null && has_sheal="true"
  local has_gstack="false"
  [[ -d "${HOME}/.claude/skills/gstack" ]] && has_gstack="true"
  local has_node="false"
  command -v node &>/dev/null && has_node="true"

  jq -n \
    --arg version "$version" \
    --arg platform "$_AIF_PLATFORM" \
    --arg machine "$machine_id" \
    --arg bash_ver "${BASH_VERSION:-unknown}" \
    --arg python_ver "$python_version" \
    --arg jq_ver "$jq_version" \
    --argjson has_sheal "$has_sheal" \
    --argjson has_gstack "$has_gstack" \
    --argjson has_node "$has_node" \
    '{
      version: $version,
      platform: $platform,
      machine: $machine,
      bash: $bash_ver,
      python: $python_ver,
      jq: $jq_ver,
      sheal: $has_sheal,
      gstack: $has_gstack,
      node: $has_node
    }' 2>/dev/null || echo "{}"
}

# Send a telemetry event — fire-and-forget, never blocks
_aif_telemetry() {
  _aif_telemetry_enabled || return 0
  local event="$1"; shift

  local base
  base=$(_aif_telemetry_base)

  # Merge event-specific fields into base
  local payload
  payload=$(echo "$base" | jq \
    --arg event "$event" \
    --arg errors "${_AIF_TELEMETRY_ERRORS:-}" \
    '. + {event: $event, errors: $errors, ts: now | todate}' 2>/dev/null) || return 0

  # Add any extra key=value pairs as fields
  local kv
  for kv in "$@"; do
    local key="${kv%%=*}"
    local val="${kv#*=}"
    payload=$(echo "$payload" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}' 2>/dev/null) || true
  done

  # Fire-and-forget
  if command -v curl &>/dev/null; then
    curl -fsSL --connect-timeout 2 --max-time 3 \
      -X POST -H "Content-Type: application/json" \
      -d "$payload" \
      "$_AIF_TELEMETRY_ENDPOINT" &>/dev/null &
  fi
}

# Record an error for inclusion in the next telemetry event
_aif_telemetry_error() {
  local phase="$1"
  local message="$2"
  # Strip any file paths from the message for privacy
  message=$(echo "$message" | sed 's|/[^ ]*||g')
  if [[ -n "$_AIF_TELEMETRY_ERRORS" ]]; then
    _AIF_TELEMETRY_ERRORS="${_AIF_TELEMETRY_ERRORS}; ${phase}:${message}"
  else
    _AIF_TELEMETRY_ERRORS="${phase}:${message}"
  fi
}

# Dependency check — validate required tools are available
check_dependencies() {
  local missing=0

  if ! command -v jq &>/dev/null; then
    echo "ERROR: 'jq' is required but not installed."
    echo "  macOS:        brew install jq"
    echo "  Ubuntu/Debian: sudo apt-get install jq"
    echo "  Fedora:       sudo dnf install jq"
    missing=1
  fi

  if ! command -v git &>/dev/null; then
    echo "ERROR: 'git' is required but not installed."
    echo "  macOS:        xcode-select --install"
    echo "  Ubuntu/Debian: sudo apt-get install git"
    missing=1
  fi

  if [[ $missing -ne 0 ]]; then
    echo ""
    echo "Install missing dependencies and try again."
    local _missing_list=""
    command -v jq &>/dev/null || _missing_list="jq"
    command -v git &>/dev/null || _missing_list="${_missing_list:+$_missing_list,}git"
    _aif_telemetry "dependency_missing" "tools=$_missing_list"
    exit 1
  fi
}

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# Timing
_AIF_PHASE_START=0
_aif_timer_start() { _AIF_PHASE_START=$SECONDS; }
_aif_timer_elapsed() {
  local elapsed=$(( SECONDS - _AIF_PHASE_START ))
  if [[ $elapsed -lt 1 ]]; then
    printf "0.%ss" "$(( (SECONDS * 10 - _AIF_PHASE_START * 10) % 10 ))"
  else
    printf "%s.%ss" "$elapsed" "$(( (SECONDS * 10 - _AIF_PHASE_START * 10) % 10 ))"
  fi
}

# Step counter for progress tracking
_AIF_STEP=0
_AIF_STEP_TOTAL=0

log_info()  { echo -e "  ${BLUE}ℹ${NC}  $*"; }
log_ok()    { echo -e "  ${GREEN}✓${NC}  $*"; }
log_warn()  { echo -e "  ${YELLOW}⚠${NC}  $*"; }
log_error() { echo -e "  ${RED}✗${NC}  $*"; }

log_step() {
  _AIF_STEP=$((_AIF_STEP + 1))
  if [[ $_AIF_STEP_TOTAL -gt 0 ]]; then
    local pct=$(( _AIF_STEP * 100 / _AIF_STEP_TOTAL ))
    local filled=$(( pct / 5 ))
    local empty=$(( 20 - filled ))
    local bar=""
    local i
    for ((i=0; i<filled; i++)); do bar+="█"; done
    for ((i=0; i<empty; i++)); do bar+="░"; done
    echo -e "  ${CYAN}├─${NC} ${DIM}[${_AIF_STEP}/${_AIF_STEP_TOTAL}]${NC} ${BOLD}$*${NC} ${DIM}${bar}${NC}"
  else
    echo -e "  ${CYAN}├─${NC} ${BOLD}$*${NC}"
  fi
}

log_phase() {
  local name="$1"
  local count="${2:-}"
  _AIF_STEP=0
  _AIF_STEP_TOTAL=0
  _aif_timer_start
  echo ""
  if [[ -n "$count" ]]; then
    _AIF_STEP_TOTAL=$count
    echo -e "  ${CYAN}┌─${NC} ${WHITE}${BOLD}${name}${NC} ${DIM}(${count} steps)${NC}"
  else
    echo -e "  ${CYAN}┌─${NC} ${WHITE}${BOLD}${name}${NC}"
  fi
  echo -e "  ${CYAN}│${NC}"
}

log_phase_done() {
  local elapsed
  elapsed=$(_aif_timer_elapsed)
  echo -e "  ${CYAN}│${NC}"
  echo -e "  ${CYAN}└─${NC} ${GREEN}done${NC} ${DIM}${elapsed}${NC}"
}

banner() {
  local version
  version="$(cat "$ROOT_DIR/VERSION" 2>/dev/null | tr -d '[:space:]')"
  echo ""
  echo -e "  ${CYAN}╔═══════════════════════════════════════════════╗${NC}"
  echo -e "  ${CYAN}║${NC}  ${WHITE}${BOLD}▄▀█ █ █▀▀ █▀█ ▄▀█ █▀▄▀█ █▀▀${NC}              ${CYAN}║${NC}"
  echo -e "  ${CYAN}║${NC}  ${WHITE}${BOLD}█▀█ █ █▀  █▀▄ █▀█ █ ▀ █ ██▄${NC}              ${CYAN}║${NC}"
  echo -e "  ${CYAN}║${NC}  ${DIM}Universal Automation Bootstrap${NC}  ${MAGENTA}v${version}${NC}   ${CYAN}║${NC}"
  echo -e "  ${CYAN}╚═══════════════════════════════════════════════╝${NC}"
  echo ""
}

# Completion summary box
_aif_summary() {
  local project="$1" stack="$2" files="$3" checks="$4" failed="$5" report="$6"
  local status_icon status_text status_color
  if [[ "$failed" -eq 0 ]]; then
    status_icon="✓"; status_text="Pipeline Complete"; status_color="$GREEN"
  else
    status_icon="⚠"; status_text="Pipeline Complete (with warnings)"; status_color="$YELLOW"
  fi
  echo ""
  echo -e "  ${CYAN}╔═══════════════════════════════════════════════╗${NC}"
  echo -e "  ${CYAN}║${NC}  ${status_color}${BOLD}${status_icon} ${status_text}${NC}$(printf '%*s' $((27 - ${#status_text})) '')${CYAN}║${NC}"
  echo -e "  ${CYAN}╠═══════════════════════════════════════════════╣${NC}"
  echo -e "  ${CYAN}║${NC}  ${DIM}Project:${NC}  ${BOLD}${project}${NC}$(printf '%*s' $((36 - ${#project})) '')${CYAN}║${NC}"
  echo -e "  ${CYAN}║${NC}  ${DIM}Stack:${NC}    ${stack}$(printf '%*s' $((36 - ${#stack})) '')${CYAN}║${NC}"
  echo -e "  ${CYAN}║${NC}  ${DIM}Files:${NC}    ${files} generated$(printf '%*s' $((26 - ${#files})) '')${CYAN}║${NC}"
  echo -e "  ${CYAN}║${NC}  ${DIM}Checks:${NC}   ${GREEN}${checks} passed${NC}, ${RED}${failed} failed${NC}$(printf '%*s' $((22 - ${#checks} - ${#failed})) '')${CYAN}║${NC}"
  echo -e "  ${CYAN}║${NC}  ${DIM}Report:${NC}   ${report}$(printf '%*s' $((36 - ${#report})) '')${CYAN}║${NC}"
  echo -e "  ${CYAN}╚═══════════════════════════════════════════════╝${NC}"
  echo ""
}

usage() {
  cat <<'EOF'
Usage: aiframework <command> [options]

Commands:
  discover    Scan a repo and produce manifest.json (deterministic, 100% coverage)
  generate    Read manifest.json and generate CLAUDE.md + all supporting files
  verify      Validate generated files against manifest (zero drift check)
  report      Generate a human-readable report of everything detected and generated
  refresh     Lightweight update: re-discover + regenerate only if drift detected
  index       Build code index for the target repo (standalone)
  run         Full pipeline: discover → generate → verify → report
  upgrade     Pull latest + re-run on all bootstrapped repos (surgical, incremental)
  stats       Show cross-repo knowledge store statistics

Options:
  --target <path>      Target repo to analyze (default: current directory)
  --manifest <path>    Path to manifest.json (default: .aiframework/manifest.json)
  --output <path>      Output directory for manifest (default: .aiframework/)
  --dry-run            Show what would be generated without writing files
  --verbose            Show detailed scanner output
  --non-interactive    Skip all user prompts (set all user_context to null)
  --no-index           Skip the code index step during discover
  --help               Show this help

Note: Enhancement is done via the /aif-enhance skill in Claude Code — no API key needed.

Examples:
  aiframework discover --target /path/to/repo
  aiframework discover --target /path/to/repo --no-index
  aiframework generate --manifest .aiframework/manifest.json
  aiframework verify
  aiframework index --target /path/to/repo
  aiframework run --target /path/to/my-project
EOF
}

# Parse arguments
COMMAND=""
TARGET_DIR="."
MANIFEST_PATH=""
OUTPUT_DIR=""
DRY_RUN=false
VERBOSE=false
NON_INTERACTIVE=false
NO_INDEX=false

parse_args() {
  if [[ $# -eq 0 ]]; then
    usage
    _aif_telemetry "error" "phase=parse" "type=no_args"
    exit 1
  fi

  # Handle --help/-h as first argument
  if [[ "$1" == "--help" || "$1" == "-h" || "$1" == "help" ]]; then
    usage
    exit 0
  fi

  # Handle --version/-v
  if [[ "$1" == "--version" || "$1" == "-v" ]]; then
    cat "$ROOT_DIR/VERSION"
    exit 0
  fi

  COMMAND="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target)    TARGET_DIR="$2"; shift 2 ;;
      --manifest)  MANIFEST_PATH="$2"; shift 2 ;;
      --output)    OUTPUT_DIR="$2"; shift 2 ;;
      --dry-run)   DRY_RUN=true; shift ;;
      --verbose)   VERBOSE=true; shift ;;
      --non-interactive) NON_INTERACTIVE=true; shift ;;
      --no-index)  NO_INDEX=true; shift ;;
      --tier)      AIF_CLI_TIER="$2"; shift 2 ;;
      --help|-h)   usage; exit 0 ;;
      *)           log_error "Unknown option: $1"; _aif_telemetry "error" "phase=parse" "type=unknown_option"; usage; exit 1 ;;
    esac
  done

  # Resolve paths
  TARGET_DIR="$(cd "$TARGET_DIR" 2>/dev/null && pwd)" || {
    log_error "Target directory does not exist: $TARGET_DIR"
    _aif_telemetry "error" "phase=init" "type=invalid_target"
    exit 1
  }

  if [[ -z "$OUTPUT_DIR" ]]; then
    OUTPUT_DIR="$TARGET_DIR/.aiframework"
  fi

  if [[ -z "$MANIFEST_PATH" ]]; then
    MANIFEST_PATH="$OUTPUT_DIR/manifest.json"
  fi
}

# Export for scanner/generator/validator modules
export TARGET_DIR MANIFEST_PATH OUTPUT_DIR DRY_RUN VERBOSE NON_INTERACTIVE
export NO_INDEX
export LIB_DIR TEMPLATES_DIR ROOT_DIR

# Knowledge store (cross-repo learning)
source "$LIB_DIR/knowledge/store.sh"

# Freshness tracking (drift detection)
source "$LIB_DIR/freshness/track.sh"

cmd_discover() {
  banner
  log_phase "DISCOVER" 13
  log_info "Scanning repo at ${BOLD}$TARGET_DIR${NC}"
  echo -e "  ${CYAN}│${NC}"

  mkdir -p "$OUTPUT_DIR"

  # Source all scanners
  source "$LIB_DIR/scanners/identity.sh"
  source "$LIB_DIR/scanners/stack.sh"
  source "$LIB_DIR/scanners/commands.sh"
  source "$LIB_DIR/scanners/structure.sh"
  source "$LIB_DIR/scanners/ci.sh"
  source "$LIB_DIR/scanners/env.sh"
  source "$LIB_DIR/scanners/quality.sh"
  source "$LIB_DIR/scanners/domain.sh"
  source "$LIB_DIR/scanners/user_context.sh"
  source "$LIB_DIR/scanners/code_index.sh"
  source "$LIB_DIR/scanners/archetype.sh"
  source "$LIB_DIR/scanners/skill_suggest.sh"
  source "$LIB_DIR/scanners/sheal.sh"

  # Initialize manifest
  MANIFEST="{}"

  # Run each scanner — each appends to MANIFEST
  # Track per-scanner outcomes for telemetry
  local _scanners_ok=0 _scanners_fail=0 _scanners_list=""

  _run_scanner() {
    local name="$1"; shift
    if "$@" 2>/dev/null; then
      _scanners_ok=$((_scanners_ok + 1))
    else
      _scanners_fail=$((_scanners_fail + 1))
      _scanners_list="${_scanners_list:+$_scanners_list,}$name"
    fi
  }

  log_step "Project Identity"
  _run_scanner "identity" scan_identity

  log_step "Stack Detection"
  _run_scanner "stack" scan_stack

  log_step "Commands & Package Manager"
  _run_scanner "commands" scan_commands

  log_step "Directory Structure"
  _run_scanner "structure" scan_structure

  log_step "CI/CD & Deploy"
  _run_scanner "ci" scan_ci

  log_step "Environment Variables"
  _run_scanner "env" scan_env

  log_step "Quality Tools"
  _run_scanner "quality" scan_quality

  log_step "Domain-Specific Concerns"
  _run_scanner "domain" scan_domain

  log_step "User Context"
  _run_scanner "user_context" scan_user_context

  if [[ "$NO_INDEX" != "true" ]]; then
    log_step "Code Index"
    _run_scanner "code_index" scan_code_index
  else
    _AIF_STEP=$((_AIF_STEP + 1))
    echo -e "  ${CYAN}├─${NC} ${DIM}[${_AIF_STEP}/${_AIF_STEP_TOTAL}]${NC} ${DIM}Code Index (skipped)${NC}"
  fi

  log_step "Archetype Detection"
  _run_scanner "archetype" scan_archetype

  log_step "Skill Suggestions"
  _run_scanner "skill_suggest" scan_skill_suggestions

  log_step "Sheal Integration"
  _run_scanner "sheal" scan_sheal || true

  log_phase_done

  # Add metadata
  MANIFEST=$(echo "$MANIFEST" | jq --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg ver "$(cat "$ROOT_DIR/VERSION")" \
    --arg target "$TARGET_DIR" \
    '. + {
      "_meta": {
        "generated_at": $ts,
        "aiframework_version": $ver,
        "target_dir": $target,
        "scanner": "aiframework/discover"
      }
    }')

  # Write manifest
  echo "$MANIFEST" | jq '.' > "$MANIFEST_PATH"

  # Save file hashes for drift detection
  freshness_save_hashes "$TARGET_DIR"

  # Record profile in knowledge store
  knowledge_record_profile "$MANIFEST"

  echo ""
  log_ok "Manifest written to ${BOLD}$MANIFEST_PATH${NC}"
  echo ""

  # Telemetry — discover outcomes
  local _d_lang _d_fw _d_arch _d_domains_count _d_files _d_ci _d_sheal_found
  _d_lang=$(echo "$MANIFEST" | jq -r '.stack.language // "unknown"' 2>/dev/null)
  _d_fw=$(echo "$MANIFEST" | jq -r '.stack.framework // "none"' 2>/dev/null)
  _d_arch=$(echo "$MANIFEST" | jq -r '.archetype.type // "unknown"' 2>/dev/null)
  _d_domains_count=$(echo "$MANIFEST" | jq '[.domain.detected_domains[]?] | length' 2>/dev/null || echo "0")
  _d_files=$(echo "$MANIFEST" | jq '.structure.total_files // 0' 2>/dev/null || echo "0")
  _d_ci=$(echo "$MANIFEST" | jq -r '.ci.provider // "none"' 2>/dev/null)
  _d_sheal_found=$(echo "$MANIFEST" | jq -r '.sheal.installed // false' 2>/dev/null)
  _aif_telemetry "discover" \
    "lang=$_d_lang" \
    "framework=$_d_fw" \
    "archetype=$_d_arch" \
    "domains=$_d_domains_count" \
    "total_files=$_d_files" \
    "ci=$_d_ci" \
    "sheal_detected=$_d_sheal_found" \
    "no_index=$NO_INDEX" \
    "scanners_ok=$_scanners_ok" \
    "scanners_fail=$_scanners_fail" \
    "scanners_failed=$_scanners_list"
}

cmd_generate() {
  banner

  if [[ ! -f "$MANIFEST_PATH" ]]; then
    log_error "Manifest not found at $MANIFEST_PATH"
    log_info "Run 'aiframework discover' first"
    _aif_telemetry "error" "phase=manifest" "type=not_found"
    exit 1
  fi

  MANIFEST=$(cat "$MANIFEST_PATH")
  export MANIFEST

  # Load config + resolve tier
  source "$LIB_DIR/config.sh"
  load_config
  resolve_tier "${AIF_CLI_TIER:-}"

  # Count total generators based on tier
  local total_steps=2  # CLAUDE.md + AGENTS.md always
  tier_includes "cursor" && format_enabled "cursor" && total_steps=$((total_steps + 1))
  tier_includes "hooks" && total_steps=$((total_steps + 1))
  tier_includes "ci" && total_steps=$((total_steps + 1))
  tier_includes "skills" && total_steps=$((total_steps + 1))
  # Sheal integration adds a step when installed and tier includes skills
  local _sheal_installed
  _sheal_installed=$(echo "$MANIFEST" | jq -r '.sheal.installed // false' 2>/dev/null)
  [[ "$_sheal_installed" == "true" ]] && tier_includes "skills" && total_steps=$((total_steps + 1))
  tier_includes "docs" && total_steps=$((total_steps + 1))
  tier_includes "tracking" && total_steps=$((total_steps + 1))
  tier_includes "vault-memory" && total_steps=$((total_steps + 1))

  log_phase "GENERATE" "$total_steps"

  # Load preserve module first — generators call its functions
  source "$LIB_DIR/generators/preserve.sh"
  _init_preserve

  source "$LIB_DIR/generators/claude_md.sh"
  source "$LIB_DIR/generators/agents_md.sh"
  source "$LIB_DIR/generators/cursor_rules.sh"
  source "$LIB_DIR/generators/hooks.sh"
  source "$LIB_DIR/generators/ci.sh"
  source "$LIB_DIR/generators/skills.sh"
  source "$LIB_DIR/generators/docs.sh"
  source "$LIB_DIR/generators/tracking.sh"
  source "$LIB_DIR/generators/vault.sh"
  source "$LIB_DIR/generators/vault_ingest.sh"
  source "$LIB_DIR/generators/sheal.sh"

  local generated=0

  # CLAUDE.md — always generated
  if format_enabled "claude"; then
    log_step "Generating CLAUDE.md"
    generate_claude_md && generated=$((generated + 1)) || true
  fi

  # AGENTS.md — always generated
  if format_enabled "agents"; then
    log_step "Generating AGENTS.md"
    generate_agents_md && generated=$((generated + 1)) || true
  fi

  # .cursorrules — standard tier+
  if tier_includes "cursor" && format_enabled "cursor"; then
    log_step "Generating .cursorrules"
    generate_cursor_rules && generated=$((generated + 1)) || true
  fi

  # Git hooks — standard tier+
  if tier_includes "hooks"; then
    log_step "Generating git hooks"
    generate_hooks && generated=$((generated + 1)) || true
  fi

  # CI workflow — standard tier+
  if tier_includes "ci"; then
    log_step "Generating CI workflow"
    generate_ci && generated=$((generated + 1)) || true
  fi

  # Custom skills — standard tier+
  if tier_includes "skills"; then
    log_step "Generating custom skills"
    generate_skills && generated=$((generated + 1)) || true
  fi

  # Sheal integration — when installed and tier includes skills
  if [[ "$_sheal_installed" == "true" ]] && tier_includes "skills"; then
    log_step "Generating sheal integration"
    generate_sheal && generated=$((generated + 1)) || true
  fi

  # Documentation scaffold — full tier+
  if tier_includes "docs"; then
    log_step "Generating documentation scaffold"
    generate_docs && generated=$((generated + 1)) || true
  fi

  # Tracking files — full tier+
  if tier_includes "tracking"; then
    log_step "Generating tracking files"
    generate_tracking && generated=$((generated + 1)) || true
  fi

  # Vault — full tier+ (memory), enterprise (full)
  if tier_includes "vault-memory"; then
    log_step "Generating agentic memory vault"
    generate_vault && generated=$((generated + 1)) || true
  fi

  log_phase_done

  echo ""
  log_ok "Generated ${BOLD}$generated/$total_steps${NC} file groups (tier: ${AIF_RESOLVED_TIER})"
  print_preserve_summary
  echo ""

  _aif_telemetry "generate" \
    "tier=${AIF_RESOLVED_TIER}" \
    "generated=$generated" \
    "total_steps=$total_steps" \
    "sheal_integrated=$_sheal_installed"
}

cmd_verify() {
  banner
  log_phase "VERIFY"

  if [[ ! -f "$MANIFEST_PATH" ]]; then
    log_error "Manifest not found at $MANIFEST_PATH"
    _aif_telemetry "error" "phase=manifest" "type=not_found"
    exit 1
  fi

  MANIFEST=$(cat "$MANIFEST_PATH")
  export MANIFEST

  source "$LIB_DIR/validators/files.sh"
  source "$LIB_DIR/validators/consistency.sh"
  source "$LIB_DIR/validators/security.sh"
  source "$LIB_DIR/validators/quality_gate.sh"
  source "$LIB_DIR/validators/freshness.sh"

  local total_checks=0
  local passed=0
  local failed=0
  local warnings=0

  echo -e "  ${CYAN}│${NC}"
  echo -e "  ${CYAN}│${NC}  ${BOLD}┌──────────────────────────────┬──────────┬─────────────────────────────┐${NC}"
  echo -e "  ${CYAN}│${NC}  ${BOLD}│ Check                        │ Status   │ Details                     │${NC}"
  echo -e "  ${CYAN}│${NC}  ${BOLD}├──────────────────────────────┼──────────┼─────────────────────────────┤${NC}"

  # Run each validator
  validate_files
  validate_consistency
  validate_security
  validate_quality_gate
  validate_freshness

  # Optional sheal runtime checks (non-blocking)
  if command -v sheal &>/dev/null; then
    local _sheal_result _sheal_status
    _sheal_result=$(sheal check --format json --project "$TARGET_DIR" --skip tests 2>/dev/null) || true
    if [[ -n "$_sheal_result" ]]; then
      _sheal_status=$(echo "$_sheal_result" | jq -r '.status // "unknown"' 2>/dev/null || echo "unknown")
      total_checks=$((total_checks + 1))
      if [[ "$_sheal_status" == "healthy" || "$_sheal_status" == "pass" ]]; then
        passed=$((passed + 1))
        printf "  ${CYAN}│${NC}  ${BOLD}│${NC} %-28s ${BOLD}│${NC} ${GREEN}%-8s${NC} ${BOLD}│${NC} %-27s ${BOLD}│${NC}\n" "Sheal Runtime" "PASS" "Runtime health OK"
      else
        warnings=$((warnings + 1))
        printf "  ${CYAN}│${NC}  ${BOLD}│${NC} %-28s ${BOLD}│${NC} ${YELLOW}%-8s${NC} ${BOLD}│${NC} %-27s ${BOLD}│${NC}\n" "Sheal Runtime" "WARN" "Check: sheal check"
      fi
    fi
  fi

  echo -e "  ${CYAN}│${NC}  ${BOLD}└──────────────────────────────┴──────────┴─────────────────────────────┘${NC}"
  echo -e "  ${CYAN}│${NC}"
  echo -e "  ${CYAN}│${NC}  ${GREEN}Passed:${NC} $passed  ${RED}Failed:${NC} $failed  ${YELLOW}Warnings:${NC} $warnings  ${DIM}Total: $total_checks${NC}"

  # Export counters for cmd_run summary
  _AIF_VERIFY_PASSED=$passed
  _AIF_VERIFY_FAILED=$failed

  log_phase_done

  echo ""
  if [[ $failed -gt 0 ]]; then
    log_error "Verification FAILED — $failed issue(s) need fixing"
    _aif_telemetry_error "verify" "failed=$failed passed=$passed"
    _aif_telemetry "verify_failed" "passed=$passed" "failed=$failed"
    exit 1
  else
    log_ok "Verification ${BOLD}PASSED${NC}"
    _aif_telemetry "verify_passed" "passed=$passed" "failed=$failed" "warnings=$warnings"
  fi
}

cmd_index() {
  banner
  log_phase "INDEX"
  log_info "Building code index for ${BOLD}$TARGET_DIR${NC}"
  mkdir -p "$OUTPUT_DIR"
  source "$LIB_DIR/scanners/code_index.sh"
  scan_code_index
  log_phase_done
  echo ""
  log_ok "Code index written to ${BOLD}$OUTPUT_DIR/code-index.json${NC}"
}

cmd_upgrade() {
  banner
  log_phase "UPGRADE"
  local old_version new_version
  old_version="$(cat "$ROOT_DIR/VERSION" 2>/dev/null | tr -d '[:space:]')"

  # Step 1: Pull latest code (aiframework is symlinked from a git clone)
  log_info "Pulling latest aiframework..."
  if (cd "$ROOT_DIR" && git pull --ff-only origin main 2>/dev/null); then
    new_version="$(cat "$ROOT_DIR/VERSION" 2>/dev/null | tr -d '[:space:]')"
    if [[ "$old_version" == "$new_version" ]]; then
      log_ok "Already at latest version (v${new_version})"
    else
      log_ok "Updated: v${old_version} → v${new_version}"
    fi
  else
    log_warn "Git pull failed — try: cd $ROOT_DIR && git pull"
    log_phase_done
    return 1
  fi

  # Step 2: Update sheal if npm available
  if command -v npm &>/dev/null; then
    log_info "Updating sheal..."
    npm install -g @liwala/sheal@latest 2>/dev/null && log_ok "sheal updated" || log_warn "sheal update failed (non-fatal)"
  fi

  # Step 3: Re-run on all known bootstrapped repos (surgical, incremental)
  local knowledge_dir="${HOME}/.aiframework/knowledge"
  local repos_refreshed=0
  local repos_skipped=0

  if [[ -d "$knowledge_dir" ]]; then
    log_info "Refreshing bootstrapped repos..."
    local profile
    for profile in "$knowledge_dir"/*.json; do
      [[ -f "$profile" ]] || continue
      local repo_path
      repo_path=$(jq -r '.repo_path // empty' "$profile" 2>/dev/null)
      [[ -z "$repo_path" || ! -d "$repo_path" ]] && { repos_skipped=$((repos_skipped + 1)); continue; }

      # Only refresh if the repo has .aiframework/ (was bootstrapped)
      if [[ -d "$repo_path/.aiframework" ]]; then
        log_info "  Refreshing ${BOLD}$(basename "$repo_path")${NC}..."
        if (cd "$repo_path" && "$ROOT_DIR/bin/aiframework" refresh --target . --non-interactive 2>/dev/null); then
          repos_refreshed=$((repos_refreshed + 1))
        else
          log_warn "  Failed to refresh $(basename "$repo_path")"
        fi
      else
        repos_skipped=$((repos_skipped + 1))
      fi
    done
  fi

  # Step 4: Refresh current repo if it's bootstrapped
  if [[ -d "$TARGET_DIR/.aiframework" && "$TARGET_DIR" != "$ROOT_DIR" ]]; then
    log_info "Refreshing current repo..."
    cmd_refresh
    repos_refreshed=$((repos_refreshed + 1))
  fi

  log_phase_done
  echo ""
  log_ok "Upgrade complete: v${new_version}, ${repos_refreshed} repo(s) refreshed, ${repos_skipped} skipped"

  _aif_telemetry "upgrade" \
    "from=$old_version" \
    "to=$new_version" \
    "repos_refreshed=$repos_refreshed" \
    "repos_skipped=$repos_skipped"
}

cmd_stats() {
  banner
  log_phase "STATS"
  knowledge_stats
  log_phase_done
  echo ""
}

cmd_report() {
  banner
  log_phase "REPORT"

  if [[ ! -f "$MANIFEST_PATH" ]]; then
    log_error "Manifest not found at $MANIFEST_PATH"
    log_info "Run 'aiframework discover' first"
    _aif_telemetry "error" "phase=manifest" "type=not_found"
    exit 1
  fi

  MANIFEST=$(cat "$MANIFEST_PATH")
  export MANIFEST

  source "$LIB_DIR/validators/files.sh"
  source "$LIB_DIR/validators/consistency.sh"
  source "$LIB_DIR/validators/security.sh"
  source "$LIB_DIR/validators/quality_gate.sh"
  source "$LIB_DIR/validators/freshness.sh"
  source "$LIB_DIR/generators/report.sh"

  generate_report
  log_phase_done
  echo ""
  log_info "Open ${BOLD}.aiframework/report.md${NC} to review what was detected and generated"
  log_info "If anything is wrong, run ${BOLD}/aif-feedback${NC} in Claude Code"
}

cmd_refresh() {
  banner
  log_phase "REFRESH"
  log_info "Checking for drift..."

  local drift_result
  drift_result=$(freshness_check_drift "$TARGET_DIR")

  # Check if learnings have accumulated since last /aif-evolve
  _aif_suggest_evolve() {
    local marker="$TARGET_DIR/.aiframework/.last_evolve_count"
    local last_count=0
    [[ -f "$marker" ]] && last_count=$(cat "$marker" 2>/dev/null | tr -d '[:space:]')
    local current_count
    current_count=$(cat "$TARGET_DIR/tools/learnings/"*-learnings.jsonl 2>/dev/null | wc -l | tr -d ' ')
    local new_learnings=$(( current_count - last_count ))
    if [[ $new_learnings -ge 5 ]]; then
      echo ""
      log_info "${YELLOW}${new_learnings} new learnings${NC} since last /aif-evolve"
      log_info "Run ${BOLD}/aif-evolve${NC} to promote learnings to CLAUDE.md rules"
    fi
  }

  if [[ "$drift_result" == "clean" ]]; then
    log_phase_done
    echo ""
    log_ok "No drift detected — files are up to date"
    _aif_suggest_evolve
    _aif_telemetry "refresh" "drift=none"
    return 0
  elif [[ "$drift_result" == "no-baseline" ]]; then
    log_warn "No baseline found — running full discover"
    log_phase_done
    _aif_telemetry "refresh" "drift=no-baseline"
    cmd_discover
    cmd_generate
    return 0
  else
    local drifted_files="${drift_result#drifted:}"
    log_warn "Drift detected in:$drifted_files"
    # Count drifted files (not their paths — privacy)
    local drift_count
    drift_count=$(echo "$drifted_files" | tr ',' '\n' | wc -l | tr -d ' ')
    _aif_telemetry "refresh" "drift=detected" "drift_count=$drift_count"
    log_info "Re-running discover + generate..."
    log_phase_done
    echo ""
    cmd_discover
    echo ""
    cmd_generate
    _write_refresh_notice "$drifted_files"
    _aif_suggest_evolve
    return 0
  fi
}

_write_refresh_notice() {
  local drifted_files="${1:-}"
  local notice_file="$OUTPUT_DIR/last-refresh.json"
  local now
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  local user
  user=$(git config user.name 2>/dev/null || echo "unknown")
  cat > "$notice_file" << EOF
{
  "refreshed_at": "$now",
  "refreshed_by": "$user",
  "drifted_files": "$drifted_files",
  "version": "$(cat "$ROOT_DIR/VERSION" 2>/dev/null || echo "unknown")"
}
EOF
}

cmd_run() {
  local _run_start=$SECONDS

  # Detect first run vs repeat
  local _is_first_run="true"
  [[ -f "$TARGET_DIR/.aiframework/manifest.json" ]] && _is_first_run="false"

  cmd_discover

  # Analysis summary (A20)
  echo ""
  echo -e "  ${CYAN}┌─${NC} ${WHITE}${BOLD}ANALYSIS SUMMARY${NC}"
  echo -e "  ${CYAN}│${NC}"
  echo -e "  ${CYAN}│${NC}  ${DIM}Project:${NC}    ${BOLD}$(echo "$MANIFEST" | jq -r '.identity.name')${NC}"
  echo -e "  ${CYAN}│${NC}  ${DIM}Language:${NC}   $(echo "$MANIFEST" | jq -r '.stack.language')"
  echo -e "  ${CYAN}│${NC}  ${DIM}Framework:${NC} $(echo "$MANIFEST" | jq -r '.stack.framework // "none"')"
  echo -e "  ${CYAN}│${NC}  ${DIM}Domains:${NC}   $(echo "$MANIFEST" | jq -r '.domain.detected_domains | length' 2>/dev/null || echo 0)"
  echo -e "  ${CYAN}│${NC}  ${DIM}Env vars:${NC}  $(echo "$MANIFEST" | jq '.env.variables | length' 2>/dev/null || echo 0)"
  echo -e "  ${CYAN}│${NC}  ${DIM}CI:${NC}        $(echo "$MANIFEST" | jq -r '.ci.provider // "none"')"
  echo -e "  ${CYAN}│${NC}"
  echo -e "  ${CYAN}└─${NC}"
  echo ""

  if [[ "$NON_INTERACTIVE" != "true" ]] && [[ -t 0 ]]; then
    read -p "  Proceed with generation? [Y/n] " confirm
    if [[ "$confirm" =~ ^[Nn] ]]; then
      log_warn "Aborted by user"
      return 1
    fi
  fi

  cmd_generate
  cmd_verify
  cmd_report
  _write_refresh_notice "full-run"

  # Completion summary
  local _run_elapsed=$(( SECONDS - _run_start ))
  local _proj _stack _lang _fw _files_gen _checks_passed _checks_failed
  _proj=$(echo "$MANIFEST" | jq -r '.identity.name // "unknown"')
  _lang=$(echo "$MANIFEST" | jq -r '.stack.language // "unknown"')
  _fw=$(echo "$MANIFEST" | jq -r '.stack.framework // ""')
  if [[ -n "$_fw" && "$_fw" != "null" && "$_fw" != "none" ]]; then
    _stack="${_lang} / ${_fw}"
  else
    _stack="${_lang}"
  fi
  _files_gen="${generated:-7}"
  _checks_passed="${_AIF_VERIFY_PASSED:-0}"
  _checks_failed="${_AIF_VERIFY_FAILED:-0}"

  _aif_summary "$_proj" "$_stack" "$_files_gen" "$_checks_passed" "$_checks_failed" ".aiframework/report.md"
  echo -e "  ${DIM}Total time: ${_run_elapsed}s${NC}"
  echo ""

  # Telemetry — track what stacks people bootstrap
  local _domains _archetype _total_files _total_symbols _vault_pages
  _domains=$(echo "$MANIFEST" | jq -r '[.domain.detected_domains[]?.name] | join(",")' 2>/dev/null || echo "none")
  _archetype=$(echo "$MANIFEST" | jq -r '.archetype.type // "unknown"' 2>/dev/null || echo "unknown")
  _total_files=$(echo "$MANIFEST" | jq -r '.structure.total_files // 0' 2>/dev/null || echo "0")
  _total_symbols=$(jq -r '._meta.total_symbols // 0' "$OUTPUT_DIR/code-index.json" 2>/dev/null || echo "0")
  _vault_pages=$(find "$TARGET_DIR/vault/wiki" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')

  # Quality metrics — measure CLAUDE.md effectiveness (integers only, zero privacy risk)
  local _claude_md="$TARGET_DIR/CLAUDE.md"
  local _claude_md_lines=0 _invariant_count=0 _gotcha_count=0 _command_count=0
  local _key_locations=0 _domains_with_invariants=0 _custom_sections=0
  local _learnings_count=0 _tier="unknown"
  if [[ -f "$_claude_md" ]]; then
    _claude_md_lines=$(wc -l < "$_claude_md" | tr -d ' ')
    _invariant_count=$(grep -c '^\- \*\*INV-' "$_claude_md" 2>/dev/null || echo "0")
    _gotcha_count=$(grep -c '^\- ' "$_claude_md" 2>/dev/null | head -1 || echo "0")
    _command_count=$(grep -cE '^\s*(make |npm |yarn |pnpm |cargo |go |python)' "$_claude_md" 2>/dev/null || echo "0")
    _key_locations=$(grep -c '^\- \*\*' "$_claude_md" 2>/dev/null || echo "0")
    # Count domains that got their own invariant rules
    _domains_with_invariants=$(find "$TARGET_DIR/.claude/rules" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
    # Custom sections: lines starting with ## that aren't in our template
    _custom_sections=$(grep -cE '^## ' "$_claude_md" 2>/dev/null || echo "0")
  fi
  # Learnings volume across all JSONL files
  _learnings_count=$(cat "$TARGET_DIR/tools/learnings/"*-learnings.jsonl 2>/dev/null | wc -l | tr -d ' ')
  # Tier from resolved config
  _tier="${AIF_RESOLVED_TIER:-unknown}"

  _aif_telemetry "run" \
    "lang=$_lang" \
    "framework=${_fw:-none}" \
    "archetype=$_archetype" \
    "domains=$_domains" \
    "total_files=$_total_files" \
    "total_symbols=$_total_symbols" \
    "vault_pages=${_vault_pages:-0}" \
    "checks_passed=$_checks_passed" \
    "checks_failed=$_checks_failed" \
    "files_generated=$_files_gen" \
    "duration=${_run_elapsed}s" \
    "first_run=$_is_first_run" \
    "non_interactive=$NON_INTERACTIVE" \
    "claude_md_lines=$_claude_md_lines" \
    "invariant_count=$_invariant_count" \
    "gotcha_count=$_gotcha_count" \
    "command_count=$_command_count" \
    "key_locations=$_key_locations" \
    "domains_with_invariants=$_domains_with_invariants" \
    "custom_sections=$_custom_sections" \
    "learnings_count=$_learnings_count" \
    "tier=$_tier"
}

# Main
parse_args "$@"

# Check dependencies only when actually running a command (not for --help/--version)
check_dependencies

case "$COMMAND" in
  discover)  cmd_discover ;;
  generate)  cmd_generate ;;
  verify)    cmd_verify ;;
  report)    cmd_report ;;
  refresh)   cmd_refresh ;;
  upgrade)   cmd_upgrade ;;
  index)     cmd_index ;;
  stats)     cmd_stats ;;
  run)       cmd_run ;;
  *)         log_error "Unknown command: $COMMAND"; _aif_telemetry "error" "phase=dispatch" "type=unknown_command"; usage; exit 1 ;;
esac
