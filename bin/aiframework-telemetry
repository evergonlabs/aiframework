#!/usr/bin/env bash
# aiframework-telemetry — Lightweight telemetry emitter for skills and hooks
#
# Usage: aiframework-telemetry <event> [key=value ...]
# Example: aiframework-telemetry skill_invoked skill=aif-review
#
# Respects opt-out: ~/.aiframework/config with 'telemetry: false'
# Fire-and-forget: never blocks, silently fails.

set -euo pipefail

_config="${HOME}/.aiframework/config"
[[ -f "$_config" ]] && grep -q 'telemetry: false' "$_config" 2>/dev/null && exit 0

event="${1:-unknown}"; shift || true

# Resolve aiframework root
_src="${BASH_SOURCE[0]}"
while [[ -L "$_src" ]]; do _src="$(readlink "$_src")"; [[ "$_src" != /* ]] && _src="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$_src"; done
_root="$(cd "$(dirname "$_src")/.." && pwd)"

version="$(cat "$_root/VERSION" 2>/dev/null | tr -d '[:space:]' || echo '0.0.0')"
machine=$(echo "${HOSTNAME:-x}:${USER:-x}" | shasum -a 256 2>/dev/null | cut -d' ' -f1 || echo "x")
platform="unknown"
case "$(uname -s 2>/dev/null)" in Darwin*) platform="macos";; Linux*) platform="linux";; MINGW*|MSYS*) platform="windows";; esac

has_sheal="false"; command -v sheal &>/dev/null && has_sheal="true"
has_gstack="false"; [[ -d "${HOME}/.claude/skills/gstack" ]] && has_gstack="true"

# Build extra fields from key=value args
extra=""
for kv in "$@"; do
  key="${kv%%=*}"
  val="${kv#*=}"
  extra="${extra:+$extra, }\"$key\": \"$val\""
done

payload="{\"event\":\"$event\",\"version\":\"$version\",\"machine\":\"$machine\",\"platform\":\"$platform\",\"sheal\":$has_sheal,\"gstack\":$has_gstack${extra:+, $extra}}"

command -v curl &>/dev/null && curl -fsSL --connect-timeout 2 --max-time 3 \
  -X POST -H "Content-Type: application/json" \
  -d "$payload" \
  "https://telemetry.evergonlabs.com/v1/event" &>/dev/null &

exit 0
