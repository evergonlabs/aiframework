  "targets": {
    "fly-io": {
      "display": "Fly.io",
      "marker_files": ["fly.toml"],
      "marker_dirs": [],
      "commands": {
        "deploy": "fly deploy",
        "status": "fly status",
        "logs": "fly logs"
      },
      "category": "paas"
    },
