      "qa_rules": [
        "Use smart pointers (unique_ptr, shared_ptr) — no raw new/delete in application code",
        "All RAII resources must follow Rule of Five (or Rule of Zero)",
        "Prefer std::string_view and std::span over raw pointers for non-owning references"
      ]
