{
  "$schema": "language-registry/v1",
  "$description": "Data-driven language/framework detection registry for aiframework. Add new languages here without code changes.",
  "languages": {
    "java": {
      "display": "Java",
      "marker_files": ["pom.xml", "build.gradle", "build.gradle.kts", ".mvn/wrapper/maven-wrapper.properties"],
      "extensions": [".java"],
      "package_managers": {
        "maven": {
          "manifest": "pom.xml",
          "lock_file": null,
          "commands": {
            "install": "mvn install",
            "build": "mvn package",
            "test": "mvn test",
            "lint": "mvn checkstyle:check",
            "format": "mvn spotless:apply"
          }
        },
        "gradle": {
          "manifest": "build.gradle",
          "lock_file": "gradle.lockfile",
          "commands": {
            "install": "./gradlew dependencies",
            "build": "./gradlew build",
            "test": "./gradlew test",
            "lint": "./gradlew checkstyleMain",
            "format": "./gradlew spotlessApply"
          }
        }
      },
      "frameworks": {
        "spring-boot": {
          "detection": {
            "dependency_markers": ["spring-boot-starter", "org.springframework.boot"],
            "file_patterns": ["**/Application.java", "**/application.yml", "**/application.properties"]
          },
          "display": "Spring Boot"
        },
        "quarkus": {
          "detection": {
            "dependency_markers": ["io.quarkus", "quarkus-bom"],
            "file_patterns": ["**/application.properties", "**/resources/META-INF/microprofile-config.properties"]
          },
          "display": "Quarkus"
        },
        "micronaut": {
          "detection": {
            "dependency_markers": ["io.micronaut", "micronaut-bom"],
            "file_patterns": ["**/application.yml"]
          },
          "display": "Micronaut"
        }
      },
      "qa_rules": [
        "All Spring beans must use constructor injection (no field injection with @Autowired)",
        "Database migrations managed through Flyway or Liquibase — no manual DDL",
        "All REST endpoints must have integration tests with MockMvc or WebTestClient"
      ]
    },
    "csharp": {
      "display": "C#",
      "marker_files": ["*.csproj", "*.sln", "global.json", "Directory.Build.props"],
      "extensions": [".cs"],
      "package_managers": {
        "dotnet": {
          "manifest": "*.csproj",
          "lock_file": "packages.lock.json",
          "commands": {
            "install": "dotnet restore",
            "build": "dotnet build",
            "test": "dotnet test",
            "lint": "dotnet format --verify-no-changes",
            "format": "dotnet format"
          }
        }
      },
      "frameworks": {
        "aspnet": {
          "detection": {
            "dependency_markers": ["Microsoft.AspNetCore", "Microsoft.NET.Sdk.Web"],
            "file_patterns": ["**/Program.cs", "**/Startup.cs", "**/appsettings.json"]
          },
          "display": "ASP.NET"
        },
        "blazor": {
          "detection": {
            "dependency_markers": ["Microsoft.AspNetCore.Components", "Microsoft.AspNetCore.Components.WebAssembly"],
            "file_patterns": ["**/*.razor", "**/App.razor"]
          },
          "display": "Blazor"
        },
        "maui": {
          "detection": {
            "dependency_markers": ["Microsoft.Maui", "Microsoft.NET.Sdk.Maui"],
            "file_patterns": ["**/MauiProgram.cs"]
          },
          "display": ".NET MAUI"
        }
      },
      "qa_rules": [
        "All public APIs must have XML documentation comments",
        "Use IOptions<T> pattern for configuration — no static config access",
        "All async methods must use CancellationToken parameters"
      ]
    },
    "php": {
      "display": "PHP",
      "marker_files": ["composer.json", "artisan", "index.php"],
      "extensions": [".php"],
      "package_managers": {
        "composer": {
          "manifest": "composer.json",
          "lock_file": "composer.lock",
          "commands": {
            "install": "composer install",
            "build": null,
            "test": "vendor/bin/phpunit",
            "lint": "vendor/bin/phpstan analyse",
            "format": "vendor/bin/php-cs-fixer fix"
          }
        }
      },
      "frameworks": {
        "laravel": {
          "detection": {
            "dependency_markers": ["laravel/framework", "laravel/laravel"],
            "file_patterns": ["artisan", "**/routes/web.php", "**/routes/api.php"]
          },
          "display": "Laravel"
        },
        "symfony": {
          "detection": {
            "dependency_markers": ["symfony/framework-bundle", "symfony/symfony"],
            "file_patterns": ["**/config/bundles.php", "**/symfony.lock"]
          },
          "display": "Symfony"
        },
        "wordpress": {
          "detection": {
            "dependency_markers": ["johnpbloch/wordpress-core", "roots/wordpress"],
            "file_patterns": ["wp-config.php", "**/wp-content/themes/*/functions.php"]
          },
          "display": "WordPress"
        }
      },
      "qa_rules": [
        "All database queries must use Eloquent/Doctrine ORM — no raw SQL without review",
        "All user input must be validated through Form Requests or Validator component",
        "Composer dependencies must be locked — never commit without composer.lock"
      ]
    },
    "swift": {
      "display": "Swift",
      "marker_files": ["Package.swift", "*.xcodeproj", "*.xcworkspace"],
      "extensions": [".swift"],
      "package_managers": {
        "spm": {
          "manifest": "Package.swift",
          "lock_file": "Package.resolved",
          "commands": {
            "install": "swift package resolve",
            "build": "swift build",
            "test": "swift test",
            "lint": "swiftlint",
            "format": "swift-format format -r ."
          }
        },
        "cocoapods": {
          "manifest": "Podfile",
          "lock_file": "Podfile.lock",
          "commands": {
            "install": "pod install",
            "build": "xcodebuild build",
            "test": "xcodebuild test",
            "lint": "swiftlint",
            "format": null
          }
        }
      },
      "frameworks": {
        "vapor": {
          "detection": {
            "dependency_markers": ["vapor/vapor"],
            "file_patterns": ["**/configure.swift", "**/routes.swift"]
          },
          "display": "Vapor"
        },
        "swiftui": {
          "detection": {
            "dependency_markers": [],
            "file_patterns": ["**/*App.swift", "**/*View.swift"],
            "import_markers": ["import SwiftUI"]
          },
          "display": "SwiftUI"
        },
        "uikit": {
          "detection": {
            "dependency_markers": [],
            "file_patterns": ["**/*ViewController.swift", "**/Main.storyboard"],
            "import_markers": ["import UIKit"]
          },
          "display": "UIKit"
        }
      },
      "qa_rules": [
        "All async operations must use Swift concurrency (async/await) — no completion handlers in new code",
        "All views must support Dynamic Type and VoiceOver accessibility",
        "No force unwraps (!) in production code — use guard let or if let"
      ]
    },
    "kotlin": {
      "display": "Kotlin",
      "marker_files": ["build.gradle.kts", "settings.gradle.kts"],
      "extensions": [".kt", ".kts"],
      "package_managers": {
        "gradle": {
          "manifest": "build.gradle.kts",
          "lock_file": "gradle.lockfile",
          "commands": {
            "install": "./gradlew dependencies",
            "build": "./gradlew build",
            "test": "./gradlew test",
            "lint": "./gradlew detekt",
            "format": "./gradlew ktlintFormat"
          }
        }
      },
      "frameworks": {
        "ktor": {
          "detection": {
            "dependency_markers": ["io.ktor", "ktor-server"],
            "file_patterns": ["**/Application.kt", "**/plugins/Routing.kt"]
          },
          "display": "Ktor"
        },
        "spring-boot": {
          "detection": {
            "dependency_markers": ["org.springframework.boot", "spring-boot-starter"],
            "file_patterns": ["**/Application.kt", "**/application.yml"]
          },
          "display": "Spring Boot (Kotlin)"
        },
        "android": {
          "detection": {
            "dependency_markers": ["com.android.application", "androidx.core"],
            "file_patterns": ["**/AndroidManifest.xml", "**/MainActivity.kt"]
          },
          "display": "Android"
        }
      },
      "qa_rules": [
        "All data classes must be immutable (val only) — no mutable state in DTOs",
        "Coroutine scopes must be properly structured — no GlobalScope usage",
        "Nullable types must be handled explicitly — no unsafe casts or !!"
      ]
    },
    "dart": {
      "display": "Dart",
      "marker_files": ["pubspec.yaml"],
      "extensions": [".dart"],
      "package_managers": {
        "pub": {
          "manifest": "pubspec.yaml",
          "lock_file": "pubspec.lock",
          "commands": {
            "install": "dart pub get",
            "build": "dart compile exe",
            "test": "dart test",
            "lint": "dart analyze",
            "format": "dart format ."
          }
        }
      },
      "frameworks": {
        "flutter": {
          "detection": {
            "dependency_markers": ["flutter"],
            "file_patterns": ["**/lib/main.dart", "android/app/build.gradle", "ios/Runner.xcodeproj"]
          },
          "display": "Flutter"
        },
        "shelf": {
          "detection": {
            "dependency_markers": ["shelf"],
            "file_patterns": []
          },
          "display": "Shelf"
        }
      },
      "qa_rules": [
        "All widgets must be either StatelessWidget or use Riverpod/Bloc for state — no raw StatefulWidgets for complex state",
        "All public API surfaces must have dartdoc comments",
        "Flutter golden tests required for critical UI components"
      ]
