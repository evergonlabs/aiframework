            "format": "clang-format -i"
          }
        },
        "conan": {
          "manifest": "conanfile.txt",
          "lock_file": "conan.lock",
          "commands": {
            "install": "conan install .",
            "build": "conan build .",
            "test": null,
            "lint": null,
            "format": null
