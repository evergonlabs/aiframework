      "invariants": [
        {
          "id": "API-1",
          "rule": "All endpoints must validate input — no unvalidated user data",
          "severity": "critical"
        },
        {
          "id": "API-2",
          "rule": "All endpoints must return consistent error response format",
          "severity": "medium"
        },
        {
          "id": "API-3",
          "rule": "Rate limiting must be configured for all public endpoints",
          "severity": "high"
        }
      ],
      "security_concerns": [
        "input-validation",
        "rate-limiting",
        "cors-configuration",
        "api-key-exposure",
        "broken-access-control"
      ]
    },
