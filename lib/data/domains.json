        "**/drizzle/**",
        "**/db/**",
        "**/database/**",
        "**/seeds/**",
        "**/seeders/**",
        "**/fixtures/**"
      ],
      "dependency_markers": {
        "python": [
          "sqlalchemy",
          "django.db",
          "tortoise-orm",
          "peewee",
          "prisma",
          "alembic"
        ],
        "typescript": [
          "prisma",
          "@prisma/client",
          "drizzle-orm",
          "typeorm",
          "sequelize",
          "knex",
          "kysely"
        ],
        "javascript": [
          "sequelize",
          "knex",
          "mongoose",
          "typeorm",
          "prisma"
        ],
        "ruby": [
          "activerecord",
          "sequel",
          "rom-rb"
        ],
        "go": [
          "gorm.io/gorm",
          "database/sql",
          "sqlx",
          "ent"
        ],
        "rust": [
          "diesel",
          "sqlx",
          "sea-orm",
          "surrealdb"
        ],
        "java": [
          "spring-data-jpa",
          "hibernate",
          "mybatis",
          "jooq"
        ],
        "csharp": [
          "Microsoft.EntityFrameworkCore",
          "Dapper",
          "NHibernate"
        ],
        "php": [
          "doctrine/orm",
          "illuminate/database",
          "cycle/orm"
        ],
        "elixir": [
          "ecto",
          "ecto_sql"
        ]
      },
      "invariants": [
        {
          "id": "DB-1",
          "rule": "All database access through ORM/query builder — no raw SQL without explicit review",
          "severity": "high"
        },
        {
          "id": "DB-2",
          "rule": "All migrations must be reversible (up + down)",
          "severity": "medium"
        },
        {
          "id": "DB-3",
          "rule": "Indexes must exist for all frequently queried columns and foreign keys",
          "severity": "medium"
        }
      ],
      "security_concerns": [
        "sql-injection",
        "data-exposure",
        "unencrypted-pii",
        "missing-access-control",
        "connection-string-leakage"
      ]
    },
