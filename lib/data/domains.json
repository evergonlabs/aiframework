{
  "$schema": "domain-registry/v1",
  "$description": "Data-driven domain detection registry for aiframework. Add new domains here without code changes.",
  "domains": {
    "auth": {
      "display": "Authentication & Authorization",
      "file_patterns": [
        "**/auth/**",
        "**/authentication/**",
        "**/authorization/**",
        "**/login*",
        "**/signup*",
        "**/register*",
        "**/middleware/auth*",
        "**/guards/**",
        "**/oauth*",
        "**/saml*",
        "**/sso*",
        "**/jwt*",
        "**/token*",
        "**/session*",
        "**/passport*",
        "**/keycloak*"
      ],
      "dependency_markers": {
        "python": [
          "django-allauth",
          "python-jose",
          "PyJWT",
          "authlib",
          "fastapi-users"
        ],
        "typescript": [
          "passport",
          "jsonwebtoken",
          "express-session",
          "bcrypt",
          "next-auth",
          "@auth/core",
          "@clerk/nextjs",
          "lucia",
          "lucia-auth",
          "supabase",
          "@supabase/auth-helpers-nextjs",
          "jose",
          "arctic"
        ],
        "javascript": [
          "passport",
          "jsonwebtoken",
          "express-session",
          "bcrypt",
          "next-auth",
          "@auth/core",
          "@clerk/nextjs",
          "lucia",
          "lucia-auth",
          "supabase",
          "@supabase/auth-helpers-nextjs",
          "jose",
          "arctic"
        ],
        "ruby": [
          "devise",
          "omniauth",
          "doorkeeper",
          "pundit"
        ],
        "go": [
          "golang-jwt/jwt",
          "coreos/go-oidc",
          "casbin"
        ],
        "rust": [
          "jsonwebtoken",
          "actix-identity",
          "axum-login"
        ],
        "java": [
          "spring-security",
          "spring-boot-starter-security",
          "keycloak-spring"
        ],
        "csharp": [
          "Microsoft.AspNetCore.Authentication",
          "Microsoft.Identity"
        ],
        "php": [
          "laravel/sanctum",
          "tymon/jwt-auth",
          "laravel/passport"
        ],
        "elixir": [
          "guardian",
          "pow",
          "ueberauth"
        ]
      },
      "invariants": [
        {
          "id": "AUTH-1",
          "rule": "All auth tokens must have expiration — no infinite-lived tokens",
          "severity": "critical"
        },
        {
          "id": "AUTH-2",
          "rule": "Password hashing must use bcrypt/argon2/scrypt — no MD5/SHA for passwords",
          "severity": "critical"
        },
        {
          "id": "AUTH-3",
          "rule": "All protected routes must check authorization — no auth bypass paths",
          "severity": "critical"
        }
      ],
      "security_concerns": [
        "credential-storage",
        "session-fixation",
        "token-expiry",
        "privilege-escalation",
        "brute-force-protection",
        "oauth-redirect-validation"
      ]
    },
    "database": {
      "display": "Database & Data Layer",
      "file_patterns": [
        "**/migrations/**",
        "**/migrate/**",
        "**/models/**",
        "**/entities/**",
        "**/schemas/**",
        "**/repositories/**",
        "**/dao/**",
